@page
@model Microsoft.AspNetCore.Identity.UI.V4.Pages.Account.Internal.ForgotPasswordModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="max-w-sm mx-auto mt-12 bg-white p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">
    <div class="text-center mb-8">
        <h1 class="text-2xl font-semibold text-slate-900 tracking-tight">Şifrenizi mi Unuttunuz?</h1>
        <p class="text-sm text-slate-500 mt-2">E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim.</p>
    </div>

    <form method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm text-center"></div>

        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">E-posta</label>
            <input asp-for="Input.Email" type="email" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 transition-all text-sm" autocomplete="username" aria-required="true" placeholder="ornek@mail.com" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <button type="submit" class="w-full bg-slate-900 hover:bg-black text-white font-medium py-3 rounded-2xl transition-all shadow-md hover:shadow-lg mt-4">
            Yenileme Linki Gönder
        </button>
    </form>
    
    <div class="mt-8 text-center">
        <!-- İkonlu geri dönüş linki (Doğrudan href ile garantili çalışır) -->
        <a href="/Identity/Account/Login" class="inline-flex items-center text-sm text-slate-500 hover:text-slate-900 font-medium transition-colors">
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Giriş sayfasına dön
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}