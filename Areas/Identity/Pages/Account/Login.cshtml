@page
@model Microsoft.AspNetCore.Identity.UI.V4.Pages.Account.Internal.LoginModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="max-w-sm mx-auto mt-12 bg-white p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">
    <div class="text-center mb-8">
        <h1 class="text-2xl font-semibold text-slate-900 tracking-tight">Hoş Geldiniz</h1>
        <p class="text-sm text-slate-500 mt-2">Devam etmek için hesabınıza giriş yapın</p>
    </div>

    <form id="account" method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm text-center"></div>
        
        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">E-posta</label>
            <input asp-for="Input.Email" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm" autocomplete="username" aria-required="true" placeholder="ornek@mail.com" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div>
            <label asp-for="Input.Password" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">Şifre</label>
            <input asp-for="Input.Password" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div class="flex items-center justify-between pl-1">
            <label asp-for="Input.RememberMe" class="flex items-center space-x-2 cursor-pointer">
                <input asp-for="Input.RememberMe" class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500" />
                <span class="text-sm text-slate-600">Beni Hatırla</span>
            </label>
            <a id="forgot-password" asp-page="./ForgotPassword" class="text-sm text-blue-600 hover:text-blue-700 font-medium transition-colors">Şifremi unuttum</a>
        </div>

        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 rounded-2xl transition-all shadow-sm mt-2">
            Giriş Yap
        </button>
    </form>

    <div class="mt-8 text-center">
        <p class="text-sm text-slate-500">
            Hesabınız yok mu? 
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-blue-600 hover:text-blue-700 font-medium transition-colors">Hemen kayıt olun</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}