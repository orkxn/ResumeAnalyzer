@page
@model Microsoft.AspNetCore.Identity.UI.V4.Pages.Account.Internal.LoginModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="max-w-sm mx-auto mt-12 bg-white p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">
    <div class="text-center mb-8">
        <h1 class="text-2xl font-semibold text-slate-900 tracking-tight">Hoş Geldiniz</h1>
        <p class="text-sm text-slate-500 mt-2">Devam etmek için hesabınıza giriş yapın</p>
    </div>

    <form id="account" method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm text-center"></div>
        
        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">E-posta</label>
            <input asp-for="Input.Email" type="email" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 transition-all text-sm" autocomplete="username" aria-required="true" placeholder="ornek@mail.com" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div>
            <label asp-for="Input.Password" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">Şifre</label>
            <input asp-for="Input.Password" type="password" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 transition-all text-sm" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div class="flex items-center justify-between pl-1">
            <div class="flex items-center space-x-2">
                <!-- Checkbox için id ve type manuel eklendi -->
                <input asp-for="Input.RememberMe" type="checkbox" id="RememberMeCheck" class="w-4 h-4 text-slate-900 bg-gray-100 border-gray-300 rounded focus:ring-slate-900 cursor-pointer" />
                <label for="RememberMeCheck" class="text-sm text-slate-600 cursor-pointer mb-0">Beni Hatırla</label>
            </div>
            <!-- Link için href manuel eklendi -->
            <a href="/Identity/Account/ForgotPassword" class="text-sm text-slate-600 hover:text-slate-900 font-medium transition-colors">Şifremi unuttum</a>
        </div>

        <button type="submit" class="w-full bg-slate-900 hover:bg-black text-white font-medium py-3 rounded-2xl transition-all shadow-md hover:shadow-lg mt-2">
            Giriş Yap
        </button>
    </form>

    <div class="mt-8 text-center">
        <p class="text-sm text-slate-500">
            Hesabınız yok mu? 
            <!-- Link için href manuel eklendi -->
            <a href="/Identity/Account/Register?returnUrl=@Model.ReturnUrl" class="text-slate-900 hover:text-black font-medium transition-colors underline decoration-slate-300 underline-offset-4">Hemen kayıt olun</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}