@page
@model Microsoft.AspNetCore.Identity.UI.V4.Pages.Account.Internal.RegisterModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="max-w-sm mx-auto mt-12 bg-white p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">
    <div class="text-center mb-8">
        <h1 class="text-2xl font-semibold text-slate-900 tracking-tight">Hesap Oluştur</h1>
        <p class="text-sm text-slate-500 mt-2">CV Analiz platformuna katılın</p>
    </div>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm text-center"></div>

        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">E-posta</label>
            <input asp-for="Input.Email" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm" autocomplete="username" aria-required="true" placeholder="ornek@mail.com" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div>
            <label asp-for="Input.Password" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">Şifre</label>
            <input asp-for="Input.Password" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div>
            <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-slate-700 mb-1.5 ml-1">Şifre Tekrarı</label>
            <input asp-for="Input.ConfirmPassword" class="w-full px-4 py-2.5 bg-[#fbfbfd] border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 rounded-2xl transition-all shadow-sm mt-4">
            Kayıt Ol
        </button>
    </form>
    
    <div class="mt-8 text-center">
        <p class="text-sm text-slate-500">
            Zaten bir hesabınız var mı? 
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-blue-600 hover:text-blue-700 font-medium transition-colors">Giriş yapın</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}