@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- Arka Planda Çok Hafif Dekoratif Bir Parlama (Apple Tarzı) -->
<div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
    <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-slate-200 to-slate-400 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
</div>

<div class="relative pb-12 sm:pb-20 lg:pb-24">
    
    <!-- Hero (Başlık) Alanı -->
    <div class="text-center max-w-3xl mx-auto px-4 mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 mb-6">
            Özgeçmişinizi saniyeler içinde <br class="hidden sm:block" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-600 to-slate-900">yapay zeka ile analiz edin.</span>
        </h1>
        <p class="text-lg leading-8 text-slate-500">
            PDF veya Word formatındaki dosyanızı yükleyin. Akıllı algoritmalarımız güçlü yönlerinizi, eksiklerinizi ve potansiyel eşleşmelerinizi anında ortaya çıkarsın.
        </p>
    </div>

    <!-- Dev Sürükle-Bırak Alanı -->
    <div class="max-w-3xl mx-auto px-4">
        <!-- Form, veriyi doğrudan ResumesController içindeki Upload aksiyonuna gönderecek -->
        <form asp-controller="Resumes" asp-action="Upload" method="post" enctype="multipart/form-data" class="relative group">
            
            <div class="absolute -inset-1 bg-gradient-to-r from-slate-200 to-slate-300 rounded-[2rem] blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
            
            <div class="relative bg-white/80 backdrop-blur-xl border border-slate-200 rounded-[2rem] p-10 sm:p-16 shadow-2xl shadow-slate-200/50 text-center transition-all">
                
                <input type="file" name="resumeFile" accept=".pdf,.doc,.docx" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" required />
                
                <div class="mx-auto w-20 h-20 mb-6 text-slate-300 group-hover:text-slate-800 transition-colors duration-300 group-hover:scale-110 transform">
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-full h-full">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                </div>
                
                <h3 class="text-xl font-semibold text-slate-900 mb-2">Yüklemek için tıklayın veya sürükleyin</h3>
                <p class="text-sm text-slate-500 mb-8">PDF, DOC veya DOCX (Maksimum 5MB)</p>
                
                <button type="submit" class="relative z-20 inline-flex justify-center items-center px-8 py-3.5 text-sm font-semibold text-white bg-slate-900 rounded-full hover:bg-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                    Analize Başla
                </button>
            </div>
        </form>
    </div>

    <!-- Güven / Özellik Bandı -->
    <div class="mt-20 max-w-4xl mx-auto px-4 grid grid-cols-1 sm:grid-cols-3 gap-8 text-center border-t border-slate-200/60 pt-10">
        <div>
            <h4 class="text-slate-900 font-semibold mb-1">Hızlı Sonuç</h4>
            <p class="text-sm text-slate-500">Saniyeler içinde detaylı skorlama.</p>
        </div>
        <div>
            <h4 class="text-slate-900 font-semibold mb-1">Akıllı Eşleşme</h4>
            <p class="text-sm text-slate-500">Sektör standartlarına göre kıyaslama.</p>
        </div>
        <div>
            <h4 class="text-slate-900 font-semibold mb-1">Gizlilik Odaklı</h4>
            <p class="text-sm text-slate-500">Verileriniz analizden sonra silinir.</p>
        </div>
    </div>

</div>