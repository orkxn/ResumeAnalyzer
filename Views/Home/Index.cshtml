@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- Hero -->
<section class="py-16 sm:py-24 text-center relative overflow-hidden">
    <!-- Decorative blur orb -->
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-blue-500/10 dark:bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-4">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-medium text-blue-700 bg-blue-100 dark:bg-blue-900/50 dark:text-blue-300 rounded-full">
            <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
            Yapay Zeka Destekli Analiz
        </span>

        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-6 leading-tight">
            Özgeçmişinizi saniyeler içinde
            <span class="text-blue-600 dark:text-blue-400"> yapay zeka ile analiz edin.</span>
        </h1>

        <p class="text-lg text-gray-500 dark:text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed">
            Dosyalarınızı sisteme ekleyin. Akıllı algoritmalarımız güçlü yönlerinizi, eksiklerinizi ve potansiyel eşleşmelerinizi anında ortaya çıkarsın.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a asp-controller="Resumes" asp-action="Upload"
               class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 transform">
                <i data-lucide="upload" class="w-4 h-4"></i>
                Analize Başla
            </a>
            <a asp-controller="Resumes" asp-action="Index"
               class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-xl transition-all shadow-sm hover:-translate-y-0.5 transform">
                <i data-lucide="layout-grid" class="w-4 h-4"></i>
                Özgeçmişlerim
            </a>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-12 max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="p-6 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center mb-4">
                <i data-lucide="zap" class="w-5 h-5 text-blue-600 dark:text-blue-400"></i>
            </div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-2">Hızlı Sonuç</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Saniyeler içinde detaylı skorlama ve yapay zeka önerileri.</p>
        </div>
        <div class="p-6 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/50 rounded-xl flex items-center justify-center mb-4">
                <i data-lucide="git-compare" class="w-5 h-5 text-purple-600 dark:text-purple-400"></i>
            </div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-2">Akıllı Eşleşme</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Sektör standartlarına ve iş ilanlarına göre kıyaslama.</p>
        </div>
        <div class="p-6 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-green-100 dark:bg-green-900/50 rounded-xl flex items-center justify-center mb-4">
                <i data-lucide="shield-check" class="w-5 h-5 text-green-600 dark:text-green-400"></i>
            </div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-2">Gizlilik Odaklı</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Verileriniz güvende, güçlü şifreleme ve gizlilik politikası.</p>
        </div>
    </div>
</section>