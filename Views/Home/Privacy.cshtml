}

<div class="max-w-3xl mx-auto pb-12">
    <h1 class="text-3xl font-semibold text-slate-900 dark:text-white tracking-tight mb-4 transition-colors">@ViewData["Title"]</h1>

    <div class="bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-8 shadow-sm transition-colors">
