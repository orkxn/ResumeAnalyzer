@{
    ViewData["Title"] = "Özgeçmişler";
}

<div class="max-w-5xl mx-auto pb-12">
    
    <!-- Başlık Alanı (dark:text-white eklendi) -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-semibold text-slate-900 dark:text-white tracking-tight transition-colors">Özgeçmişler</h1>
            <p class="text-sm text-slate-500 dark:text-neutral-400 mt-1 transition-colors">Yüklediğiniz tüm özgeçmişler ve analiz sonuçları.</p>
        </div>
        <a asp-controller="Resumes" asp-action="Upload" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white dark:text-neutral-900 bg-slate-900 dark:bg-neutral-200 rounded-full hover:bg-black dark:hover:bg-neutral-300 transition-all shadow-sm">
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Yeni Yükle
        </a>
    </div>

    <!-- PDF Kartları Grid Alanı -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- Örnek Kart 1 (dark:bg-[#121212] ve dark:border-neutral-800 eklendi) -->
        <div class="bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group">
            <div class="flex items-start justify-between mb-4">
                <div class="p-3 bg-slate-50 dark:bg-neutral-800 rounded-2xl group-hover:bg-slate-100 dark:group-hover:bg-neutral-700 transition-colors">
                    <svg class="w-6 h-6 text-slate-400 dark:text-neutral-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                </div>
                <!-- Skor Badge -->
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 border border-green-100 dark:border-green-800/50">
                    88 Skor
                </span>
            </div>
            
            <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-1 truncate transition-colors">Eren_Kurt_CV_2026.pdf</h3>
            <p class="text-xs text-slate-500 dark:text-neutral-400 mb-6 transition-colors">Yüklenme: 13 Temmuz 2026</p>
            
            <div class="flex space-x-2">
                <a asp-controller="Resumes" asp-action="Details" class="flex-1 text-center px-4 py-2 bg-slate-50 dark:bg-neutral-200 hover:bg-slate-100 dark:hover:bg-neutral-300 text-sm font-medium text-slate-700 dark:text-neutral-900 border border-transparent rounded-xl transition-colors">
                    Analizi İncele
                </a>
                <button class="px-3 py-2 bg-slate-50 dark:bg-neutral-800 hover:bg-red-50 dark:hover:bg-red-900/30 text-slate-400 hover:text-red-600 dark:text-neutral-400 dark:hover:text-red-400 border border-transparent dark:border-neutral-700 rounded-xl transition-colors" title="Sil">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                </button>
            </div>
        </div>

    </div>
</div>