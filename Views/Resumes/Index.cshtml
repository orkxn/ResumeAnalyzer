@model ResumeAnalyzer.ViewModels.ResumeIndexViewModel
@{
    ViewData["Title"] = "Özgeçmişler";
}

<div class="max-w-5xl mx-auto pb-12">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Özgeçmişler</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1.5">Yüklediğiniz tüm özgeçmişler ve analiz sonuçları.</p>
        </div>
        <a asp-controller="Resumes" asp-action="Upload"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-colors shadow-sm">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Yeni Yükle
        </a>
    </div>

    @if (Model?.Resumes == null || !Model.Resumes.Any())
    {
        <!-- Empty State -->
        <div class="text-center py-24 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm">
            <div class="w-14 h-14 bg-gray-100 dark:bg-gray-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="file-x" class="w-7 h-7 text-gray-400 dark:text-gray-500"></i>
            </div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1">Özgeçmiş bulunamadı</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Yapay zeka analizi için ilk özgeçmişinizi yükleyin.</p>
            <a asp-controller="Resumes" asp-action="Upload"
               class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-colors shadow-sm">
                <i data-lucide="upload" class="w-4 h-4"></i>
                Özgeçmiş Yükle
            </a>
        </div>
    }
    else
    {
        <!-- CV Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            @foreach (var resume in Model.Resumes)
            {
                <div id="card-@resume.Id"
                     class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-5 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col"
                     style="transition: opacity 0.3s ease, transform 0.3s ease;">
                    <div class="flex items-start justify-between mb-4">
                        <div class="p-2.5 bg-blue-50 dark:bg-blue-900/30 rounded-xl">
                            <i data-lucide="file-text" class="w-5 h-5 text-blue-600 dark:text-blue-400"></i>
                        </div>
                        @if (resume.Score.HasValue)
                        {
                            var score = resume.Score.Value;
                            var badgeClass = score >= 70
                                ? "bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 border-green-200 dark:border-green-800"
                                : score >= 40
                                    ? "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400 border-yellow-200 dark:border-yellow-800"
                                    : "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 border-red-200 dark:border-red-800";
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold border @badgeClass">
                                @resume.Score puan
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">
                                Analiz Yok
                            </span>
                        }
                    </div>

                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1 truncate" title="@resume.FileName">
                        @resume.FileName
                    </h3>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mb-5 flex items-center gap-1">
                        <i data-lucide="calendar" class="w-3 h-3"></i>
                        @resume.CreatedAt.ToString("dd MMMM yyyy HH:mm")
                    </p>

                    <div class="flex gap-2 mt-auto">
                        <a asp-controller="Resumes" asp-action="Details" asp-route-id="@resume.Id"
                           class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 text-xs font-semibold text-gray-700 dark:text-gray-200 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 border border-gray-200 dark:border-gray-700 rounded-xl transition-colors">
                            <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                            Analizi İncele
                        </a>
                        <form id="deleteForm-@resume.Id" asp-controller="Resumes" asp-action="Delete" asp-route-id="@resume.Id" method="post" class="inline-block m-0 p-0">
                            <button type="button"
                                    class="p-2 bg-gray-50 dark:bg-gray-800 hover:bg-red-50 dark:hover:bg-red-900/30 text-gray-400 hover:text-red-600 dark:text-gray-500 dark:hover:text-red-400 border border-gray-200 dark:border-gray-700 rounded-xl transition-colors"
                                    title="Sil" onclick="triggerDelete(@resume.Id, '@resume.FileName')">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-between border-t border-gray-200 dark:border-gray-800 pt-6 mt-10">
                <p class="text-sm text-gray-500 dark:text-gray-400 hidden sm:block">
                    Toplam <span class="font-semibold text-gray-900 dark:text-white">@Model.TotalPages</span> sayfa, şu an <span class="font-semibold text-gray-900 dark:text-white">@Model.CurrentPage</span>. sayfa.
                </p>
                <nav class="flex items-center gap-1" aria-label="Sayfalama">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                           class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-gray-600 dark:text-gray-400 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                            <i data-lucide="chevron-left" class="w-4 h-4"></i>
                        </a>
                    }
                    else
                    {
                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-gray-300 dark:text-gray-600 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 cursor-not-allowed">
                            <i data-lucide="chevron-left" class="w-4 h-4"></i>
                        </span>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span aria-current="page" class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm font-semibold text-white bg-blue-600 border border-blue-600">@i</span>
                        }
                        else
                        {
                            <a asp-action="Index" asp-route-page="@i"
                               class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">@i</a>
                        }
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                           class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-gray-600 dark:text-gray-400 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                        </a>
                    }
                    else
                    {
                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-gray-300 dark:text-gray-600 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 cursor-not-allowed">
                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                        </span>
                    }
                </nav>
            </div>
        }
    }
</div>

<!-- Undo Toast -->
<div id="undoToast"
     class="fixed bottom-6 left-1/2 -translate-x-1/2 flex items-center justify-between gap-6 px-5 py-3.5 rounded-2xl shadow-2xl z-50 w-[90%] max-w-md
            bg-gray-900 dark:bg-white text-white dark:text-gray-900
            border border-gray-800 dark:border-gray-200
            transition-all duration-300 translate-y-20 opacity-0 pointer-events-none">
    <div class="flex items-center gap-2.5 min-w-0">
        <i data-lucide="circle-check" class="w-4 h-4 text-green-400 dark:text-green-600 shrink-0"></i>
        <span id="undoToastText" class="text-xs font-medium truncate">Özgeçmiş silindi.</span>
    </div>
    <button id="undoButton" class="text-xs font-bold text-blue-400 hover:text-blue-300 dark:text-blue-600 dark:hover:text-blue-700 uppercase tracking-wider shrink-0 transition-colors">
        Geri Al
    </button>
</div>

@section Scripts {
    <script>
        let pendingDeleteId = null;
        let pendingDeleteTimeout = null;

        function triggerDelete(resumeId, fileName) {
            if (pendingDeleteId !== null) executePendingDelete();

            const card = document.getElementById('card-' + resumeId);
            if (card) {
                card.style.opacity = '0';
                card.style.transform = 'scale(0.95)';
                setTimeout(() => card.classList.add('hidden'), 300);
            }

            pendingDeleteId = resumeId;
            document.getElementById('undoToastText').innerText = `"${fileName}" adlı özgeçmiş silinmiştir.`;
            const toast = document.getElementById('undoToast');
            toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
            lucide.createIcons();

            pendingDeleteTimeout = setTimeout(executePendingDelete, 5000);
        }

        function executePendingDelete() {
            if (pendingDeleteId === null) return;
            const form = document.getElementById('deleteForm-' + pendingDeleteId);
            if (form) form.submit();
            pendingDeleteId = null;
            clearTimeout(pendingDeleteTimeout);
            pendingDeleteTimeout = null;
        }

        document.getElementById('undoButton').addEventListener('click', function () {
            if (pendingDeleteId === null) return;
            clearTimeout(pendingDeleteTimeout);
            pendingDeleteTimeout = null;

            const card = document.getElementById('card-' + pendingDeleteId);
            if (card) {
                card.classList.remove('hidden');
                setTimeout(() => { card.style.opacity = '1'; card.style.transform = 'scale(1)'; }, 50);
            }

            document.getElementById('undoToast').classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
            pendingDeleteId = null;
        });

        window.addEventListener('beforeunload', function () {
            if (pendingDeleteId !== null) executePendingDelete();
        });
    </script>
}