@model ResumeAnalyzer.ViewModels.ResumeIndexViewModel
@{
    ViewData["Title"] = "Özgeçmişler";
}

<div class="max-w-5xl mx-auto pb-12">
    
    <!-- Başlık Alanı -->
    <div class="flex items-center justify-between mb-8 px-4 sm:px-0">
        <div>
            <h1 class="text-3xl font-semibold text-slate-900 dark:text-white tracking-tight transition-colors">Özgeçmişler</h1>
            <p class="text-slate-500 dark:text-neutral-400 mt-2 transition-colors">Yüklediğiniz tüm özgeçmişler ve analiz sonuçları.</p>
        </div>
        <a asp-controller="Resumes" asp-action="Upload" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white dark:text-neutral-900 bg-slate-900 dark:bg-neutral-200 rounded-full hover:bg-black dark:hover:bg-neutral-300 transition-all shadow-sm">
            <svg width="16" height="16" class="mr-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Yeni Yükle
        </a>
    </div>

    @if (Model?.Resumes == null || !Model.Resumes.Any())
    {
        <!-- Boş Durum (Empty State) -->
        <div class="text-center py-20 bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-8 shadow-sm">
            <svg width="40" height="40" class="mx-auto text-slate-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5v6m3-3H9m4.062-10.062L10.5 4.5H4.5A2.25 2.25 0 0 0 2.25 6.75v10.5A2.25 2.25 0 0 0 4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V9.75A2.25 2.25 0 0 0 19.5 7.5h-5.379a1.5 1.5 0 0 1-1.06-.44z" />
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">Özgeçmiş bulunamadı</h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">Yapay zeka analizi için ilk özgeçmişinizi yükleyin.</p>
            <div class="mt-8">
                <a asp-controller="Resumes" asp-action="Upload" class="inline-flex items-center justify-center px-5 py-2 text-sm font-semibold text-white dark:text-neutral-900 bg-slate-900 dark:bg-neutral-200 rounded-full hover:bg-black dark:hover:bg-neutral-300 transition-all shadow-sm">
                    Özgeçmiş Yükle
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- PDF Kartları Grid Alanı (3 Kolon x 2 Satır olacak şekilde 6 öğe sınırıyla) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 px-4 sm:px-0">
            @foreach (var resume in Model.Resumes)
            {
                <div id="card-@resume.Id" class="bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group">
                    <div class="flex items-start justify-between mb-4">
                        <div class="p-3 bg-slate-50 dark:bg-neutral-800 rounded-2xl group-hover:bg-slate-100 dark:group-hover:bg-neutral-700 transition-colors">
                            <svg width="24" height="24" class="text-slate-400 dark:text-neutral-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                            </svg>
                        </div>
                        @if (resume.Score.HasValue)
                        {
                            <!-- Skor Badge -->
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 border border-green-100 dark:border-green-800/50">
                                @resume.Score Skor
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400 border border-yellow-100 dark:border-yellow-800/50">
                                Analiz Yok
                            </span>
                        }
                    </div>
                    
                    <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-1 truncate transition-colors" title="@resume.FileName">
                        @resume.FileName
                    </h3>
                    <p class="text-xs text-slate-500 dark:text-neutral-400 mb-6 transition-colors">
                        Yüklenme: @resume.CreatedAt.ToString("dd MMMM yyyy HH:mm")
                    </p>
                    
                    <div class="flex space-x-2 items-center">
                        <a asp-controller="Resumes" asp-action="Details" asp-route-id="@resume.Id" class="flex-1 text-center px-4 py-2 bg-slate-50 dark:bg-neutral-200 hover:bg-slate-100 dark:hover:bg-neutral-300 text-sm font-medium text-slate-700 dark:text-neutral-900 border border-transparent rounded-xl transition-colors">
                            Analizi İncele
                        </a>
                        
                        <form id="deleteForm-@resume.Id" asp-controller="Resumes" asp-action="Delete" asp-route-id="@resume.Id" method="post" class="delete-form inline-block m-0 p-0">
                            <button type="button" class="p-2 bg-slate-50 dark:bg-neutral-800 hover:bg-red-50 dark:hover:bg-red-900/30 text-slate-400 hover:text-red-600 dark:text-neutral-400 dark:hover:text-red-400 border border-transparent dark:border-neutral-700 rounded-xl transition-colors" title="Sil" onclick="triggerDelete(@resume.Id, '@resume.FileName')">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- Sayfalama (Pagination) Kontrolleri -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-between border-t border-slate-200/60 dark:border-neutral-800 pt-6 mt-12 px-4 sm:px-0">
                <div class="flex flex-1 justify-between sm:hidden">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" class="relative inline-flex items-center rounded-xl bg-white dark:bg-neutral-900 border border-slate-200/60 dark:border-neutral-800 px-4 py-2 text-sm font-medium text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">Önceki</a>
                    }
                    else
                    {
                        <span class="relative inline-flex items-center rounded-xl bg-white dark:bg-neutral-900 border border-slate-100 dark:border-neutral-800/40 px-4 py-2 text-sm font-medium text-slate-300 dark:text-neutral-600 cursor-not-allowed">Önceki</span>
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" class="relative ml-3 inline-flex items-center rounded-xl bg-white dark:bg-neutral-900 border border-slate-200/60 dark:border-neutral-800 px-4 py-2 text-sm font-medium text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">Sonraki</a>
                    }
                    else
                    {
                        <span class="relative ml-3 inline-flex items-center rounded-xl bg-white dark:bg-neutral-900 border border-slate-100 dark:border-neutral-800/40 px-4 py-2 text-sm font-medium text-slate-300 dark:text-neutral-600 cursor-not-allowed">Sonraki</span>
                    }
                </div>
                <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
                    <div>
                        <p class="text-sm text-slate-500 dark:text-neutral-400">
                            Toplam <span class="font-semibold text-slate-900 dark:text-white">@Model.TotalPages</span> sayfa içerisinden <span class="font-semibold text-slate-900 dark:text-white">@Model.CurrentPage</span>. sayfa gösteriliyor.
                        </p>
                    </div>
                    <div>
                        <nav class="isolate inline-flex -space-x-px rounded-xl bg-white dark:bg-neutral-900 border border-slate-200/60 dark:border-neutral-800 p-1 gap-1" aria-label="Pagination">
                            <!-- Önceki Sayfa -->
                            @if (Model.HasPreviousPage)
                            {
                                <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" class="relative inline-flex items-center rounded-lg p-2 text-slate-500 dark:text-neutral-400 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">
                                    <span class="sr-only">Önceki</span>
                                    <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="relative inline-flex items-center rounded-lg p-2 text-slate-300 dark:text-neutral-700 cursor-not-allowed">
                                    <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                            }

                            <!-- Sayfa Numaraları -->
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                if (i == Model.CurrentPage)
                                {
                                    <span aria-current="page" class="relative z-10 inline-flex items-center rounded-lg bg-slate-900 dark:bg-neutral-200 px-3 py-1.5 text-xs font-semibold text-white dark:text-neutral-900 focus:z-20">@i</span>
                                }
                                else
                                {
                                    <a asp-action="Index" asp-route-page="@i" class="relative inline-flex items-center rounded-lg bg-transparent px-3 py-1.5 text-xs font-semibold text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">@i</a>
                                }
                            }

                            <!-- Sonraki Sayfa -->
                            @if (Model.HasNextPage)
                            {
                                <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" class="relative inline-flex items-center rounded-lg p-2 text-slate-500 dark:text-neutral-400 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">
                                    <span class="sr-only">Sonraki</span>
                                    <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="relative inline-flex items-center rounded-lg p-2 text-slate-300 dark:text-neutral-700 cursor-not-allowed">
                                    <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                            }
                        </nav>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Floating Undo Toast Notification -->
<div id="undoToast" class="fixed bottom-6 left-1/2 transform -translate-x-1/2 bg-slate-900 dark:bg-neutral-900 text-white px-5 py-3.5 rounded-2xl shadow-2xl flex items-center justify-between gap-6 z-50 transition-all duration-300 translate-y-20 opacity-0 pointer-events-none w-[90%] max-w-md border border-slate-800 dark:border-neutral-800">
    <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span id="undoToastText" class="text-xs font-semibold truncate max-w-[200px] sm:max-w-[280px]">Özgeçmiş silindi.</span>
    </div>
    <button id="undoButton" class="text-xs font-bold text-sky-400 hover:text-sky-300 transition-colors shrink-0 uppercase tracking-wider">Geri Al</button>
</div>

@section Scripts {
    <script>
        let pendingDeleteId = null;
        let pendingDeleteTimeout = null;

        function triggerDelete(resumeId, fileName) {
            // Eğer bekleyen başka bir silme varsa hemen gönder
            if (pendingDeleteId !== null) {
                executePendingDelete();
            }

            // Kartı arayüzde animasyonla gizle
            const card = document.getElementById('card-' + resumeId);
            if (card) {
                card.style.opacity = '0';
                card.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    card.classList.add('hidden');
                }, 300);
            }

            pendingDeleteId = resumeId;

            // Toast bildirimini güncelle ve göster
            const toast = document.getElementById('undoToast');
            const toastText = document.getElementById('undoToastText');
            toastText.innerText = `"${fileName}" adlı özgeçmiş silinmiştir.`;
            
            toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');

            // 5 saniye sonra sunucuya silme isteği gönder
            pendingDeleteTimeout = setTimeout(() => {
                executePendingDelete();
            }, 5000);
        }

        function executePendingDelete() {
            if (pendingDeleteId === null) return;

            const form = document.getElementById('deleteForm-' + pendingDeleteId);
            if (form) {
                form.submit();
            }

            pendingDeleteId = null;
            if (pendingDeleteTimeout) {
                clearTimeout(pendingDeleteTimeout);
                pendingDeleteTimeout = null;
            }
        }

        // Geri Al buton dinleyicisi
        document.getElementById('undoButton').addEventListener('click', function () {
            if (pendingDeleteId === null) return;

            // Zamanlayıcıyı iptal et
            clearTimeout(pendingDeleteTimeout);
            pendingDeleteTimeout = null;

            // Kartı geri göster ve canlandır
            const card = document.getElementById('card-' + pendingDeleteId);
            if (card) {
                card.classList.remove('hidden');
                setTimeout(() => {
                    card.style.opacity = '1';
                    card.style.transform = 'scale(1)';
                }, 50);
            }

            // Toast'ı gizle
            const toast = document.getElementById('undoToast');
            toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');

            pendingDeleteId = null;
        });

        // Kullanıcı sayfayı kapatır/yenilerse bekleyen silmeyi anında çalıştır
        window.addEventListener('beforeunload', function () {
            if (pendingDeleteId !== null) {
                executePendingDelete();
            }
        });
    </script>
}