@{
    ViewData["Title"] = "Özgeçmişlerim";
}

<div class="max-w-5xl mx-auto">
    <!-- Başlık ve Aksiyon Alanı -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
        <div>
            <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">Özgeçmişlerim</h1>
            <p class="text-sm text-slate-500 mt-1">Yüklediğiniz ve analiz edilen tüm özgeçmişleriniz.</p>
        </div>
        <a asp-controller="Resumes" asp-action="Upload" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white bg-slate-900 rounded-full hover:bg-black transition-all shadow-sm">
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Yeni Yükle
        </a>
    </div>

    <!-- Özgeçmiş Kartları Grid Alanı -->
    <!-- Not: Şimdilik arayüzü görmek için statik kartlar koyduk. Arkadaşın Backend'i bağladığında buraları foreach döngüsü ile veritabanından çekecek. -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- Kart 1 (Yüksek Skor) -->
        <div class="bg-white border border-slate-200/60 rounded-3xl p-6 hover:shadow-lg hover:border-slate-300 transition-all group flex flex-col h-full">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-slate-50 rounded-2xl text-slate-700 group-hover:scale-105 transition-transform">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                    Skor: 92/100
                </span>
            </div>
            
            <h3 class="text-lg font-semibold text-slate-900 mb-1 truncate" title="Eren_Kurt_CV_2026.pdf">Eren_Kurt_CV_2026.pdf</h3>
            <p class="text-xs text-slate-500 mb-6">Yüklenme: 13 Tem 2026</p>
            
            <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center">
                <a asp-controller="Resumes" asp-action="Details" asp-route-id="1" class="text-sm font-medium text-slate-700 hover:text-black transition-colors">Analizi İncele &rarr;</a>
                <button type="button" class="text-slate-400 hover:text-red-600 transition-colors" title="Sil">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Kart 2 (Orta Skor) -->
        <div class="bg-white border border-slate-200/60 rounded-3xl p-6 hover:shadow-lg hover:border-slate-300 transition-all group flex flex-col h-full">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-slate-50 rounded-2xl text-slate-700 group-hover:scale-105 transition-transform">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                    Skor: 68/100
                </span>
            </div>
            
            <h3 class="text-lg font-semibold text-slate-900 mb-1 truncate" title="Yazilim_Staj_CV.docx">Yazilim_Staj_CV.docx</h3>
            <p class="text-xs text-slate-500 mb-6">Yüklenme: 05 Haz 2026</p>
            
            <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center">
                <a asp-controller="Resumes" asp-action="Details" asp-route-id="2" class="text-sm font-medium text-slate-700 hover:text-black transition-colors">Analizi İncele &rarr;</a>
                <button type="button" class="text-slate-400 hover:text-red-600 transition-colors" title="Sil">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Yeni Yükle Kartı (Hızlı Kısayol) -->
        <a asp-controller="Resumes" asp-action="Upload" class="border-2 border-dashed border-slate-200 rounded-3xl p-6 flex flex-col items-center justify-center text-center hover:bg-slate-50 hover:border-slate-300 transition-all min-h-[220px] group">
            <div class="p-3 bg-white shadow-sm rounded-full text-slate-400 group-hover:text-slate-900 group-hover:scale-110 transition-all mb-3">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
            </div>
            <h3 class="text-sm font-medium text-slate-900">Yeni Özgeçmiş Analiz Et</h3>
            <p class="text-xs text-slate-500 mt-1">PDF veya DOCX formatında</p>
        </a>

    </div>
</div>