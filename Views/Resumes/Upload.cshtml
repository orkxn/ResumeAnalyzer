@{
    ViewData["Title"] = "Yeni Özgeçmiş Yükle";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-semibold text-slate-900 dark:text-white tracking-tight transition-colors">Yeni Özgeçmiş Yükle</h1>
        <p class="text-slate-500 dark:text-neutral-400 mt-2 transition-colors">Yapay zeka analizi için PDF veya Word formatında bir dosya seçin.</p>
    </div>

    <div class="bg-white dark:bg-[#121212] p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-black/30 border border-gray-100 dark:border-neutral-800 transition-colors">
        <form asp-controller="Resumes" asp-action="Upload" method="post" enctype="multipart/form-data" class="space-y-6">
            <!-- Hata Bilgilendirme Kutusu (Hem server hem de client tarafı için) -->
            @{
                var hasErrors = !ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0;
            }
            <div id="jsErrorContainer" class="p-3.5 bg-white border border-gray-300 text-black rounded-2xl text-xs text-center font-medium shadow-sm @(hasErrors ? "" : "hidden")">
                <ul id="jsErrorList" class="list-none text-black">
                    @if (hasErrors && ViewData.ModelState[""] != null)
                    {
                        @foreach (var error in ViewData.ModelState[""]!.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>

            <div class="border-2 border-dashed border-gray-200 dark:border-neutral-700 rounded-2xl p-12 text-center hover:bg-[#fbfbfd] dark:hover:bg-neutral-800/50 hover:border-slate-300 dark:hover:border-neutral-600 transition-all cursor-pointer relative group">

                <input type="file" id="fileInput" name="resumeFile" accept=".pdf,.doc,.docx" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" required />

                <div id="iconWrapper" class="mx-auto w-16 h-16 mb-4 text-gray-300 dark:text-neutral-600 group-hover:text-slate-800 dark:group-hover:text-neutral-300 transition-colors duration-300">
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                </div>

                <h3 id="uploadTitle" class="text-sm font-medium text-slate-900 dark:text-white mb-1 transition-colors">Dosya seçmek için tıklayın veya sürükleyin</h3>
                <p id="uploadSubtitle" class="text-xs text-slate-500 dark:text-neutral-400 transition-colors">Desteklenen formatlar: PDF, DOC, DOCX (Maks. 5MB)</p>
            </div>

            <div class="bg-slate-50 dark:bg-neutral-800/50 text-slate-700 dark:text-neutral-300 text-sm p-4 rounded-2xl flex items-start gap-3 border border-slate-100 dark:border-neutral-800 transition-colors">
                <svg class="w-5 h-5 text-slate-900 dark:text-white flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                </svg>
                <p>Özgeçmişiniz yüklendikten hemen sonra yapay zeka tarafından analiz edilecek ve veri çıkarımı yapılacaktır. Bu işlem birkaç saniye sürebilir.</p>
            </div>

            <button type="submit" class="w-full bg-slate-900 dark:bg-neutral-200 hover:bg-black dark:hover:bg-neutral-300 text-white dark:text-neutral-900 font-medium py-3 rounded-2xl transition-all shadow-md hover:shadow-lg">
                Analizi Başlat
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('fileInput').addEventListener('change', function (e) {
            var file = e.target.files[0];
            if (file) {
                var fileName = file.name;
                var fileExtension = fileName.substring(fileName.lastIndexOf('.')).toUpperCase();
                
                // Uzantı doğrulaması
                var allowedExtensions = ['.PDF', '.DOC', '.DOCX'];
                if (!allowedExtensions.includes(fileExtension)) {
                    // Hata kutusunu güncelle ve göster
                    document.getElementById('jsErrorList').innerHTML = '<li>Sadece PDF veya Word (.doc, .docx) formatındaki dosyaları yükleyebilirsiniz.</li>';
                    document.getElementById('jsErrorContainer').classList.remove('hidden');

                    e.target.value = ''; // Seçimi sıfırla
                    
                    // Arayüzü eski haline getir
                    document.getElementById('uploadTitle').innerText = "Dosya seçmek için tıklayın veya sürükleyin";
                    document.getElementById('uploadSubtitle').innerText = "Desteklenen formatlar: PDF, DOC, DOCX (Maks. 5MB)";
                    var iconWrapper = document.getElementById('iconWrapper');
                    iconWrapper.classList.remove('text-green-500', 'dark:text-green-400');
                    iconWrapper.classList.add('text-gray-300', 'dark:text-neutral-600', 'group-hover:text-slate-800', 'dark:group-hover:text-neutral-300');
                    return;
                }

                // Geçerli dosya seçildiğinde hata kutusunu gizle
                document.getElementById('jsErrorContainer').classList.add('hidden');

                var fileSize = (file.size / 1024 / 1024).toFixed(2) + " MB";

                // Başlığı dosya adı ile güncelle
                document.getElementById('uploadTitle').innerText = fileName;

                // Alt başlığı format ve boyut rozetiyle süsle
                document.getElementById('uploadSubtitle').innerHTML = 
                    '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 border border-green-100 dark:border-green-800/50">' + fileExtension + '</span> • ' + fileSize;

                // İkon rengini yeşile çevir (başarılı seçim görseli)
                var iconWrapper = document.getElementById('iconWrapper');
                iconWrapper.classList.remove('text-gray-300', 'dark:text-neutral-600', 'group-hover:text-slate-800', 'dark:group-hover:text-neutral-300');
                iconWrapper.classList.add('text-green-500', 'dark:text-green-400');
            }
        });
    </script>
}
