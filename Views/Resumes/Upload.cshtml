@{
    ViewData["Title"] = "Yeni Özgeçmiş Yükle";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Yeni Özgeçmiş Yükle</h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2">Yapay zeka analizi için PDF veya Word formatında bir dosya seçin.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm p-8">
        <form id="uploadForm" asp-controller="Resumes" asp-action="Upload" method="post" enctype="multipart/form-data" class="space-y-6">
            <!-- Error container -->
            @{
                var hasErrors = !ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0;
            }
            <div id="jsErrorContainer" class="@(hasErrors ? "" : "hidden") flex items-start gap-3 p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 rounded-xl text-sm">
                <i data-lucide="circle-x" class="w-4 h-4 shrink-0 mt-0.5"></i>
                <ul id="jsErrorList" class="list-disc list-inside space-y-1">
                    @if (hasErrors && ViewData.ModelState[""] != null)
                    {
                        @foreach (var error in ViewData.ModelState[""]!.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>

            <!-- File Drop Zone (Flowbite-style) -->
            <div id="dropZone"
                 class="relative flex flex-col items-center justify-center w-full h-56 border-2 border-dashed border-gray-300 dark:border-gray-700 rounded-2xl cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/50 hover:border-blue-400 dark:hover:border-blue-600 transition-all group">
                <input type="file" id="fileInput" name="resumeFile" accept=".pdf,.doc,.docx"
                       class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" required />
                <div class="flex flex-col items-center gap-3 pointer-events-none">
                    <div id="iconWrapper" class="w-12 h-12 text-gray-300 dark:text-gray-600 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors">
                        <i data-lucide="file-up" class="w-full h-full"></i>
                    </div>
                    <div class="text-center">
                        <p id="uploadTitle" class="text-sm font-medium text-gray-700 dark:text-gray-300">Dosya seçmek için tıklayın veya sürükleyin</p>
                        <p id="uploadSubtitle" class="text-xs text-gray-500 dark:text-gray-400 mt-1">PDF, DOC, DOCX — Maks. 5MB</p>
                    </div>
                </div>
            </div>

            <!-- Info banner -->
            <div class="flex items-start gap-3 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-900/50 rounded-xl text-sm text-blue-700 dark:text-blue-300">
                <i data-lucide="info" class="w-4 h-4 shrink-0 mt-0.5"></i>
                <p>Özgeçmişiniz yüklendikten hemen sonra yapay zeka tarafından analiz edilecektir. Bu işlem birkaç saniye sürebilir.</p>
            </div>

            <button type="submit"
                    class="w-full flex items-center justify-center gap-2 text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 font-semibold rounded-xl text-sm px-5 py-3.5 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800 transition-colors shadow-sm">
                <i data-lucide="brain-circuit" class="w-4 h-4"></i>
                Analizi Başlat
            </button>
        </form>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-white/95 dark:bg-gray-950/95 backdrop-blur-sm hidden">
    <div class="max-w-sm w-full px-6 text-center space-y-8">
        <div class="mx-auto w-16 h-16 text-blue-600 dark:text-blue-400">
            <svg class="animate-spin w-full h-full" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-20" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
        </div>
        <div class="space-y-2">
            <h2 id="loadingStatusText" class="text-xl font-semibold text-gray-900 dark:text-white">Dosyanız yükleniyor...</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400">Lütfen sayfayı kapatmayın.</p>
        </div>
        <!-- Progress bar -->
        <div class="w-full bg-gray-200 dark:bg-gray-800 rounded-full h-2 overflow-hidden">
            <div id="loadingProgressBar" class="h-full bg-blue-600 rounded-full transition-all duration-500 ease-out" style="width: 0%;"></div>
        </div>
        <p id="loadingPercentage" class="text-sm font-medium text-gray-400 dark:text-gray-500">0%</p>
    </div>
</div>

@section Scripts {
    <script>
        var dropZone = document.getElementById('dropZone');
        var fileInput = document.getElementById('fileInput');
        var uploadTitle = document.getElementById('uploadTitle');
        var iconWrapper = document.getElementById('iconWrapper');
        var allowedExtensions = ['.PDF', '.DOC', '.DOCX'];

        function showError(msg) {
            document.getElementById('jsErrorList').innerHTML = '<li>' + msg + '</li>';
            document.getElementById('jsErrorContainer').classList.remove('hidden');
        }

        fileInput.addEventListener('dragenter', function () {
            dropZone.classList.add('border-blue-400', 'dark:border-blue-600', 'bg-blue-50', 'dark:bg-blue-900/20');
            uploadTitle.innerText = "Yüklemek için dosyayı bırakın";
        });

        fileInput.addEventListener('dragover', function (e) { e.preventDefault(); });

        fileInput.addEventListener('dragleave', function () {
            dropZone.classList.remove('border-blue-400', 'dark:border-blue-600', 'bg-blue-50', 'dark:bg-blue-900/20');
            uploadTitle.innerText = fileInput.files.length > 0 ? fileInput.files[0].name : "Dosya seçmek için tıklayın veya sürükleyin";
        });

        fileInput.addEventListener('change', function (e) {
            var file = e.target.files[0];
            if (!file) return;

            var ext = file.name.substring(file.name.lastIndexOf('.')).toUpperCase();
            if (!allowedExtensions.includes(ext)) {
                showError('Sadece PDF veya Word (.doc, .docx) formatındaki dosyaları yükleyebilirsiniz.');
                e.target.value = '';
                uploadTitle.innerText = "Dosya seçmek için tıklayın veya sürükleyin";
                document.getElementById('uploadSubtitle').innerText = "PDF, DOC, DOCX — Maks. 5MB";
                iconWrapper.classList.remove('text-green-500', 'dark:text-green-400');
                iconWrapper.classList.add('text-gray-300', 'dark:text-gray-600');
                return;
            }

            document.getElementById('jsErrorContainer').classList.add('hidden');
            uploadTitle.innerText = file.name;
            var sizeMb = (file.size / 1024 / 1024).toFixed(2) + ' MB';
            document.getElementById('uploadSubtitle').innerHTML =
                '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800">' + ext + '</span> &bull; ' + sizeMb;

            iconWrapper.classList.remove('text-gray-300', 'dark:text-gray-600');
            iconWrapper.classList.add('text-green-500', 'dark:text-green-400');
            lucide.createIcons();
        });

        document.getElementById('uploadForm').addEventListener('submit', function (e) {
            if (!fileInput.files || fileInput.files.length === 0) return;
            var ext = fileInput.files[0].name.substring(fileInput.files[0].name.lastIndexOf('.')).toUpperCase();
            if (!allowedExtensions.includes(ext)) { e.preventDefault(); return; }

            document.getElementById('loadingOverlay').classList.remove('hidden');
            var statusText = document.getElementById('loadingStatusText');
            var progressBar = document.getElementById('loadingProgressBar');
            var percentageText = document.getElementById('loadingPercentage');
            var progress = 0;
            var messages = [
                { limit: 20, text: "Dosyanız yükleniyor..." },
                { limit: 45, text: "Google Drive'a kaydediliyor..." },
                { limit: 65, text: "Metin içeriği çıkartılıyor..." },
                { limit: 85, text: "Yapay zeka analiz ediyor..." },
                { limit: 95, text: "Analiz sonuçları düzenleniyor..." },
                { limit: 99, text: "Dosya kaydı tamamlanıyor..." }
            ];
            var interval = setInterval(function () {
                if (progress < 98) {
                    progress += Math.random() * 2.5 + 0.3;
                    if (progress > 98) progress = 98;
                    var pct = Math.floor(progress);
                    progressBar.style.width = pct + '%';
                    percentageText.innerText = pct + '%';
                    for (var i = 0; i < messages.length; i++) {
                        if (pct <= messages[i].limit) { statusText.innerText = messages[i].text; break; }
                    }
                } else {
                    clearInterval(interval);
                }
            }, 250);
        });
    </script>
}
