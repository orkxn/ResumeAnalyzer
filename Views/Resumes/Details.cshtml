@{
    ViewData["Title"] = "Analiz Sonuçları";
}

<div class="max-w-4xl mx-auto pb-12">

    <!-- Üst Bar: Geri Dönüş ve Dosya Adı -->
    <div class="flex items-center justify-between mb-12">
        <a asp-controller="Resumes" asp-action="Index" class="group flex items-center text-sm font-medium text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white transition-colors">
            <svg class="w-5 h-5 mr-2 text-slate-400 dark:text-neutral-500 group-hover:text-slate-900 dark:group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Özgeçmişlere Dön
        </a>
        <span class="text-sm text-slate-400 dark:text-neutral-500 font-medium bg-white dark:bg-[#121212] px-3 py-1 rounded-full border border-slate-100 dark:border-neutral-800 shadow-sm transition-colors">
            Eren_Kurt_CV_2026.pdf
        </span>
    </div>

    <!-- 1. Tepe Noktası: Dev Skor Alanı -->
    <div class="text-center mb-16">
        <div class="inline-flex flex-col items-center justify-center p-8 bg-white dark:bg-[#121212] rounded-[3rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-black/30 border border-slate-100 dark:border-neutral-800 min-w-[240px] transition-colors">
            <div class="flex items-baseline space-x-1">
                <span class="text-7xl font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors">88</span>
                <span class="text-2xl font-bold text-slate-300 dark:text-neutral-600 transition-colors">/100</span>
            </div>
            <p class="text-sm font-bold text-slate-400 dark:text-neutral-500 mt-2 uppercase tracking-widest transition-colors">ATS Uyum Skoru</p>
        </div>
    </div>

    <!-- 2. Orta Kısım: Renklendirilmiş İkili Kartlar -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

        <!-- Artılar Kartı (Zarif Yeşil Detaylar) -->
        <div class="bg-white dark:bg-[#121212] border border-green-100/50 dark:border-green-900/30 shadow-sm rounded-3xl p-8 hover:shadow-md transition-all">
            <div class="flex items-center mb-6">
                <div class="p-2 bg-green-50 dark:bg-green-900/30 rounded-xl mr-3 transition-colors">
                    <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-slate-900 dark:text-white transition-colors">Öne Çıkan Nitelikler</h3>
            </div>
            <ul class="space-y-4 text-sm text-slate-600 dark:text-neutral-400 transition-colors">
                <li class="flex items-start">
                    <span class="mr-2 text-green-500 dark:text-green-400 font-bold text-base leading-tight">+</span>
                    <span>Modern web teknolojileri (ASP.NET Core, React) konusunda güçlü bir altyapı belirtilmiş.</span>
                </li>
                <li class="flex items-start">
                    <span class="mr-2 text-green-500 dark:text-green-400 font-bold text-base leading-tight">+</span>
                    <span>Veritabanı yönetimi (Entity Framework, SQL) tecrübesi net bir şekilde projelendirilmiş.</span>
                </li>
                <li class="flex items-start">
                    <span class="mr-2 text-green-500 dark:text-green-400 font-bold text-base leading-tight">+</span>
                    <span>Eğitim bilgileri ve staj geçmişi kronolojik ve okunaklı bir sırada sunulmuş.</span>
                </li>
            </ul>
        </div>

        <!-- Eksiler Kartı (Zarif Kırmızı Detaylar) -->
        <div class="bg-white dark:bg-[#121212] border border-red-100/50 dark:border-red-900/30 shadow-sm rounded-3xl p-8 hover:shadow-md transition-all">
            <div class="flex items-center mb-6">
                <div class="p-2 bg-red-50 dark:bg-red-900/30 rounded-xl mr-3 transition-colors">
                    <svg class="w-5 h-5 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-slate-900 dark:text-white transition-colors">Gelişim Alanları</h3>
            </div>
            <ul class="space-y-4 text-sm text-slate-600 dark:text-neutral-400 transition-colors">
                <li class="flex items-start">
                    <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                    <span>Projelerin GitHub linkleri verilmiş ancak canlı (live) demo bağlantıları eksik.</span>
                </li>
                <li class="flex items-start">
                    <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                    <span>Kullanılan teknolojiler listelenmiş fakat bu teknolojilerle "neler başarıldığına" (metrik) dair veri yok.</span>
                </li>
                <li class="flex items-start">
                    <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                    <span>Özgeçmiş özeti (About Me) çok kısa tutulmuş, kariyer hedefi belirgin değil.</span>
                </li>
            </ul>
        </div>

    </div>

    <!-- 3. Alt Kısım: Yetenek Havuzu -->
    <div class="bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-8 mb-6 shadow-sm transition-colors">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-4 uppercase tracking-wider transition-colors">Tespit Edilen Yetenekler</h3>
        <div class="flex flex-wrap gap-2">
            <span class="px-4 py-1.5 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-full text-sm font-medium text-slate-700 dark:text-neutral-300 hover:border-slate-400 dark:hover:border-neutral-500 transition-colors cursor-default">ASP.NET Core</span>
            <span class="px-4 py-1.5 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-full text-sm font-medium text-slate-700 dark:text-neutral-300 hover:border-slate-400 dark:hover:border-neutral-500 transition-colors cursor-default">C#</span>
            <span class="px-4 py-1.5 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-full text-sm font-medium text-slate-700 dark:text-neutral-300 hover:border-slate-400 dark:hover:border-neutral-500 transition-colors cursor-default">Entity Framework</span>
            <span class="px-4 py-1.5 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-full text-sm font-medium text-slate-700 dark:text-neutral-300 hover:border-slate-400 dark:hover:border-neutral-500 transition-colors cursor-default">Tailwind CSS</span>
            <span class="px-4 py-1.5 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-full text-sm font-medium text-slate-700 dark:text-neutral-300 hover:border-slate-400 dark:hover:border-neutral-500 transition-colors cursor-default">SQL Server</span>
            <span class="px-4 py-1.5 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-full text-sm font-medium text-slate-700 dark:text-neutral-300 hover:border-slate-400 dark:hover:border-neutral-500 transition-colors cursor-default">Git</span>
        </div>
    </div>

    <!-- 4. Yapay Zeka Özeti -->
    <div class="bg-slate-900 dark:bg-[#121212] border border-transparent dark:border-neutral-800 rounded-3xl p-8 text-white shadow-lg dark:shadow-black/30 transition-colors">
        <div class="flex items-center mb-4">
            <svg class="w-6 h-6 text-slate-400 mr-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.428-1.428L13.5 18.75l1.178-.394a2.25 2.25 0 001.428-1.428l.394-1.183.394 1.183a2.25 2.25 0 001.428 1.428l1.178.394-1.178.394a2.25 2.25 0 00-1.428 1.428z" />
            </svg>
            <h3 class="text-lg font-medium">Yapay Zeka Değerlendirmesi</h3>
        </div>
        <p class="text-sm text-slate-300 dark:text-neutral-400 leading-relaxed transition-colors">
            İncelediğim özgeçmiş, modern web geliştirme süreçlerine hakim, altyapısı sağlam bir yazılım mühendisi profili çiziyor. Özellikle C# ve ASP.NET Core üzerindeki odaklanma, kurumsal firmalar için oldukça çekici. Ancak, projelerin somut iş etkileri (metrikler) ve canlı demo bağlantıları eksik olduğu için işe alım uzmanlarının yetkinliği doğrulaması zaman alabilir. CV'nin üst kısmına kariyer hedeflerini anlatan kısa bir profesyonel özet eklenmesi, ATS (Aday Takip Sistemleri) performansını daha da artıracaktır.
        </p>
    </div>

</div>
