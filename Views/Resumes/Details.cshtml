@model ResumeAnalyzer.ViewModels.ResumeDetailsViewModel
@{
    ViewData["Title"] = "Analiz Sonuçları";
}

<div class="max-w-4xl mx-auto pb-12">

    <!-- Top bar -->
    <div class="flex items-center justify-between mb-10">
        <a asp-controller="Resumes" asp-action="Index"
           class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
            <i data-lucide="arrow-left" class="w-4 h-4"></i>
            Özgeçmişlere Dön
        </a>
        <div class="flex items-center gap-2">
            @if (!string.IsNullOrEmpty(Model.GoogleDriveFileUrl))
            {
                <a href="@Model.GoogleDriveFileUrl" target="_blank"
                   class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">
                    <i data-lucide="external-link" class="w-3.5 h-3.5"></i>
                    Google Drive
                </a>
            }
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg max-w-[220px] truncate" title="@Model.FileName">
                <i data-lucide="file-text" class="w-3.5 h-3.5 shrink-0"></i>
                @Model.FileName
            </span>
        </div>
    </div>

    @if (Model.Analysis == null)
    {
        <div class="text-center py-20 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm">
            <div class="w-14 h-14 bg-gray-100 dark:bg-gray-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="file-question" class="w-7 h-7 text-gray-400 dark:text-gray-500"></i>
            </div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1">Analiz Sonucu Alınamadı</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Bu özgeçmişe ait bir analiz bulunamadı.</p>
        </div>
    }
    else
    {
        var score = Model.Analysis.Score;
        var scoreColor = score >= 70 ? "text-green-600 dark:text-green-400"
                       : score >= 40 ? "text-yellow-600 dark:text-yellow-400"
                       : "text-red-600 dark:text-red-400";
        var scoreRingColor = score >= 70 ? "border-green-200 dark:border-green-900"
                           : score >= 40 ? "border-yellow-200 dark:border-yellow-900"
                           : "border-red-200 dark:border-red-900";

        <!-- Score Card -->
        <div class="text-center mb-10">
            <div class="inline-flex flex-col items-center justify-center p-8 bg-white dark:bg-gray-900 border-2 @scoreRingColor rounded-3xl shadow-sm min-w-[220px]">
                <span class="text-7xl font-extrabold tracking-tight @scoreColor">@score</span>
                <span class="text-base text-gray-400 dark:text-gray-500 font-medium">/100</span>
                <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mt-2">ATS Uyum Skoru</span>
            </div>
        </div>

        <!-- Strengths & Weaknesses -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <!-- Strengths -->
            <div class="bg-white dark:bg-gray-900 border border-green-100 dark:border-green-900/50 rounded-2xl p-6 shadow-sm">
                <div class="flex items-center gap-2 mb-5">
                    <div class="p-2 bg-green-100 dark:bg-green-900/40 rounded-xl">
                        <i data-lucide="thumbs-up" class="w-4 h-4 text-green-600 dark:text-green-400"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Öne Çıkan Nitelikler</h3>
                </div>
                <ul class="space-y-3">
                    @if (Model.Analysis.Strengths != null && Model.Analysis.Strengths.Any())
                    {
                        @foreach (var strength in Model.Analysis.Strengths)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="check" class="w-4 h-4 text-green-500 dark:text-green-400 shrink-0 mt-0.5"></i>
                                <span>@strength</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-sm text-gray-400 italic">Belirtilen güçlü bir yön bulunamadı.</li>
                    }
                </ul>
            </div>

            <!-- Weaknesses -->
            <div class="bg-white dark:bg-gray-900 border border-red-100 dark:border-red-900/50 rounded-2xl p-6 shadow-sm">
                <div class="flex items-center gap-2 mb-5">
                    <div class="p-2 bg-red-100 dark:bg-red-900/40 rounded-xl">
                        <i data-lucide="thumbs-down" class="w-4 h-4 text-red-500 dark:text-red-400"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Gelişim Alanları</h3>
                </div>
                <ul class="space-y-3">
                    @if (Model.Analysis.Weaknesses != null && Model.Analysis.Weaknesses.Any())
                    {
                        @foreach (var weakness in Model.Analysis.Weaknesses)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="minus" class="w-4 h-4 text-red-400 dark:text-red-400 shrink-0 mt-0.5"></i>
                                <span>@weakness</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-sm text-gray-400 italic">Belirtilen gelişim alanı bulunamadı.</li>
                    }
                </ul>
            </div>
        </div>

        <!-- AI Suggestions -->
        <div class="bg-gray-900 dark:bg-gray-950 border border-gray-800 rounded-2xl p-6 shadow-lg">
            <div class="flex items-center gap-2 mb-5">
                <i data-lucide="brain-circuit" class="w-5 h-5 text-blue-400"></i>
                <h3 class="text-sm font-semibold text-white">Yapay Zeka İyileştirme Önerileri</h3>
            </div>
            <ul class="space-y-3">
                @if (Model.Analysis.Suggestions != null && Model.Analysis.Suggestions.Any())
                {
                    @foreach (var suggestion in Model.Analysis.Suggestions)
                    {
                        <li class="flex items-start gap-2 text-sm text-gray-300">
                            <i data-lucide="chevron-right" class="w-4 h-4 text-blue-400 shrink-0 mt-0.5"></i>
                            <span>@suggestion</span>
                        </li>
                    }
                }
                else
                {
                    <li class="text-sm text-gray-500 italic">Herhangi bir öneri oluşturulmadı.</li>
                }
            </ul>

            <div class="mt-6 pt-4 border-t border-gray-800 flex flex-col sm:flex-row justify-between gap-2 text-xs text-gray-600">
                <span class="flex items-center gap-1">
                    <i data-lucide="cpu" class="w-3.5 h-3.5"></i>
                    Model: @(Model.Analysis.ModelUsed ?? "bilinmiyor")
                </span>
                <span class="flex items-center gap-1">
                    <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                    @Model.Analysis.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                </span>
            </div>
        </div>
    }
</div>
