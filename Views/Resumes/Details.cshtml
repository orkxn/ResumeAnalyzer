@model ResumeAnalyzer.Models.Resume
@{
    ViewData["Title"] = "Analiz Sonuçları";
}

<div class="max-w-4xl mx-auto pb-12">

    <!-- Üst Bar: Geri Dönüş ve Dosya Adı -->
    <div class="flex items-center justify-between mb-12">
        <a asp-controller="Resumes" asp-action="Index" class="group flex items-center text-sm font-medium text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white transition-colors">
            <svg class="w-5 h-5 mr-2 text-slate-400 dark:text-neutral-500 group-hover:text-slate-900 dark:group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Özgeçmişlere Dön
        </a>
        
        <div class="flex items-center gap-3">
            @if (!string.IsNullOrEmpty(Model.GoogleDriveFileUrl))
            {
                <a href="@Model.GoogleDriveFileUrl" target="_blank" class="text-xs font-semibold bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-3 py-1.5 rounded-full border border-blue-100 dark:border-blue-800/50 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-all flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                    Google Drive'da Aç
                </a>
            }
            <span class="text-sm text-slate-400 dark:text-neutral-500 font-medium bg-white dark:bg-[#121212] px-3 py-1.5 rounded-full border border-slate-100 dark:border-neutral-800 shadow-sm transition-colors max-w-[250px] truncate" title="@Model.FileName">
                @Model.FileName
            </span>
        </div>
    </div>

    @if (Model.Analysis == null)
    {
        <!-- Analiz Yükleniyor Veya Yok -->
        <div class="text-center py-20 bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-8 shadow-sm">
            <svg class="animate-spin mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">Analiz Sonucu Alınamadı</h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">Bu özgeçmişe ait bir analiz bulunamadı.</p>
        </div>
    }
    else
    {
        <!-- 1. Tepe Noktası: Dev Skor Alanı -->
        <div class="text-center mb-16">
            <div class="inline-flex flex-col items-center justify-center p-8 bg-white dark:bg-[#121212] rounded-[3rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-black/30 border border-slate-100 dark:border-neutral-800 min-w-[240px] transition-colors">
                <div class="flex items-baseline space-x-1">
                    <span class="text-7xl font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors">@Model.Analysis.Score</span>
                    <span class="text-2xl font-bold text-slate-300 dark:text-neutral-600 transition-colors">/100</span>
                </div>
                <p class="text-sm font-bold text-slate-400 dark:text-neutral-500 mt-2 uppercase tracking-widest transition-colors">ATS Uyum Skoru</p>
            </div>
        </div>

        <!-- 2. Orta Kısım: Renklendirilmiş İkili Kartlar -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

            <!-- Artılar Kartı (Zarif Yeşil Detaylar) -->
            <div class="bg-white dark:bg-[#121212] border border-green-100/50 dark:border-green-900/30 shadow-sm rounded-3xl p-8 hover:shadow-md transition-all">
                <div class="flex items-center mb-6">
                    <div class="p-2 bg-green-50 dark:bg-green-900/30 rounded-xl mr-3 transition-colors">
                        <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white transition-colors">Öne Çıkan Nitelikler</h3>
                </div>
                <ul class="space-y-4 text-sm text-slate-600 dark:text-neutral-400 transition-colors">
                    @if (Model.Analysis.Strengths != null && Model.Analysis.Strengths.Any())
                    {
                        @foreach (var strength in Model.Analysis.Strengths)
                        {
                            <li class="flex items-start">
                                <span class="mr-2 text-green-500 dark:text-green-400 font-bold text-base leading-tight">+</span>
                                <span>@strength</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-slate-400 italic">Belirtilen güçlü bir yön bulunamadı.</li>
                    }
                </ul>
            </div>

            <!-- Gelişim Alanları Kartı (Zarif Kırmızı Detaylar) -->
            <div class="bg-white dark:bg-[#121212] border border-red-100/50 dark:border-red-900/30 shadow-sm rounded-3xl p-8 hover:shadow-md transition-all">
                <div class="flex items-center mb-6">
                    <div class="p-2 bg-red-50 dark:bg-red-900/30 rounded-xl mr-3 transition-colors">
                        <svg class="w-5 h-5 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white transition-colors">Gelişim Alanları</h3>
                </div>
                <ul class="space-y-4 text-sm text-slate-600 dark:text-neutral-400 transition-colors">
                    @if (Model.Analysis.Weaknesses != null && Model.Analysis.Weaknesses.Any())
                    {
                        @foreach (var weakness in Model.Analysis.Weaknesses)
                        {
                            <li class="flex items-start">
                                <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                                <span>@weakness</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-slate-400 italic">Belirtilen gelişim alanı bulunamadı.</li>
                    }
                </ul>
            </div>

        </div>

        <!-- 3. Yapay Zeka Önerileri -->
        <div class="bg-slate-900 dark:bg-[#121212] border border-transparent dark:border-neutral-800 rounded-3xl p-8 text-white shadow-lg dark:shadow-black/30 transition-colors">
            <div class="flex items-center mb-6">
                <svg class="w-6 h-6 text-slate-400 mr-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.428-1.428L13.5 18.75l1.178-.394a2.25 2.25 0 001.428-1.428l.394-1.183.394 1.183a2.25 2.25 0 001.428 1.428l1.178.394-1.178.394a2.25 2.25 0 00-1.428 1.428z" />
                </svg>
                <h3 class="text-lg font-medium">Yapay Zeka İyileştirme Önerileri</h3>
            </div>
            
            <ul class="space-y-3 text-sm text-slate-300 dark:text-neutral-400 list-disc list-inside">
                @if (Model.Analysis.Suggestions != null && Model.Analysis.Suggestions.Any())
                {
                    @foreach (var suggestion in Model.Analysis.Suggestions)
                    {
                        <li>@suggestion</li>
                    }
                }
                else
                {
                    <li class="italic">Herhangi bir öneri oluşturulmadı.</li>
                }
            </ul>

            <div class="mt-8 pt-4 border-t border-slate-800 dark:border-neutral-800 flex justify-between text-xs text-slate-500 dark:text-neutral-500">
                <span>Kullanılan Model: @(Model.Analysis.ModelUsed ?? "llama3")</span>
                <span>Analiz Tarihi: @Model.Analysis.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
        </div>
    }
</div>
