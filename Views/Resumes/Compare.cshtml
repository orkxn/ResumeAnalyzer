@{
    ViewData["Title"] = "Karşılaştırma";
}

<div class="max-w-5xl mx-auto pb-12">
    
    <!-- Başlık Alanı -->
    <div class="text-center mb-12">
        <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">Özgeçmiş Karşılaştırma</h1>
        <p class="text-sm text-slate-500 mt-2">İki farklı özgeçmişi özellik bazında yan yana inceleyin.</p>
    </div>

    <!-- Seçim Alanı (Dropdownlar) -->
    <!-- Not: Backend bağlandığında bu select'ler kullanıcının veritabanındaki dosyalarıyla dolacak -->
    <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-end mb-12 px-4 sm:px-0">
        <div class="text-center">
            <label class="block text-xs font-medium text-slate-500 mb-2 uppercase tracking-wider">1. Özgeçmiş</label>
            <select class="w-full bg-white border border-slate-200 rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 shadow-sm focus:ring-2 focus:ring-slate-200 focus:outline-none appearance-none text-center cursor-pointer hover:border-slate-300 transition-colors">
                <option>Eren_Kurt_Guncel_CV.pdf</option>
            </select>
        </div>
        
        <div class="pb-3 px-4">
            <span class="text-[10px] font-bold text-slate-300 uppercase tracking-widest text-center block">Vs</span>
        </div>
        
        <div class="text-center">
            <label class="block text-xs font-medium text-slate-500 mb-2 uppercase tracking-wider">2. Özgeçmiş</label>
            <select class="w-full bg-white border border-slate-200 rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 shadow-sm focus:ring-2 focus:ring-slate-200 focus:outline-none appearance-none text-center cursor-pointer hover:border-slate-300 transition-colors">
                <option>Eren_Kurt_Eski_CV.pdf</option>
            </select>
        </div>
    </div>

    <!-- Karşılaştırma Tablosu (Grid Satırları) -->
    <div class="space-y-4">
        
        <!-- Satır 1: Skor -->
        <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-center bg-white p-6 sm:p-8 rounded-[2rem] border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
            <div class="text-center"><span class="text-5xl font-extrabold text-slate-900 tracking-tight">88</span></div>
            <div class="w-28 text-center"><span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">ATS Skoru</span></div>
            <div class="text-center"><span class="text-5xl font-extrabold text-slate-900 tracking-tight opacity-50">62</span></div>
        </div>

        <!-- Satır 2: Teknolojiler -->
        <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-center bg-white p-6 sm:p-8 rounded-[2rem] border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
            <div class="flex flex-wrap justify-center gap-2">
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">ASP.NET Core</span>
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">Flutter</span>
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">Firebase</span>
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">Machine Learning</span>
            </div>
            <div class="w-28 text-center"><span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Temel Odak</span></div>
            <div class="flex flex-wrap justify-center gap-2 opacity-70">
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">C#</span>
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">HTML/CSS</span>
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 rounded-full text-xs font-medium text-slate-700">Algoritmalar</span>
            </div>
        </div>

        <!-- Satır 3: Güçlü Yönler -->
        <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white p-6 sm:p-8 rounded-[2rem] border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
            <ul class="text-sm text-slate-600 space-y-3 px-2 sm:px-6">
                <li class="flex items-start">
                    <span class="mr-2 text-green-500 font-bold text-base leading-tight">+</span>
                    <span>Siren Bilişim staj tecrübesi ve aktif mobil uygulama (LoyaltyApp vb.) geliştirme süreçleri net aktarılmış.</span>
                </li>
                <li class="flex items-start">
                    <span class="mr-2 text-green-500 font-bold text-base leading-tight">+</span>
                    <span>Veritabanı yönetimi ve API entegrasyonu modern standartlara uygun.</span>
                </li>
            </ul>
            <div class="w-28 text-center pt-1"><span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Güçlü Yönler</span></div>
            <ul class="text-sm text-slate-600 space-y-3 px-2 sm:px-6 opacity-70">
                <li class="flex items-start">
                    <span class="mr-2 text-green-500 font-bold text-base leading-tight">+</span>
                    <span>Yazılım mühendisliği temel eğitim bilgileri okunaklı.</span>
                </li>
            </ul>
        </div>

        <!-- Satır 4: Eksikler -->
        <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white p-6 sm:p-8 rounded-[2rem] border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
            <ul class="text-sm text-slate-600 space-y-3 px-2 sm:px-6">
                <li class="flex items-start">
                    <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                    <span>Makine öğrenmesi (Random Forest, Isolation Forest vb.) çalışmaları belirtilmiş ancak GitHub veya Kaggle repolarının linkleri eksik.</span>
                </li>
            </ul>
            <div class="w-28 text-center pt-1"><span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Eksikler</span></div>
            <ul class="text-sm text-slate-600 space-y-3 px-2 sm:px-6 opacity-70">
                <li class="flex items-start">
                    <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                    <span>Kariyer hedefi belirsiz.</span>
                </li>
                <li class="flex items-start">
                    <span class="mr-2 text-red-400 font-bold text-base leading-tight">-</span>
                    <span>Somut proje örnekleri bulunmuyor.</span>
                </li>
            </ul>
        </div>

    </div>
</div>