@{
    ViewData["Title"] = "Karşılaştırma";
    var resumesList = ViewBag.ResumesList as List<ResumeAnalyzer.Models.Resume> ?? new List<ResumeAnalyzer.Models.Resume>();
    var resume1 = ViewBag.Resume1 as ResumeAnalyzer.Models.Resume;
    var resume2 = ViewBag.Resume2 as ResumeAnalyzer.Models.Resume;
}

<div class="max-w-5xl mx-auto pb-12">

    <!-- Başlık Alanı -->
    <div class="text-center mb-12">
        <h1 class="text-3xl font-semibold text-slate-900 dark:text-white tracking-tight transition-colors">Özgeçmiş Karşılaştırma</h1>
        <p class="text-sm text-slate-500 dark:text-neutral-400 mt-2 transition-colors">İki farklı özgeçmişi özellik bazında yan yana inceleyin.</p>
    </div>

    <!-- Seçim Alanı (Dropdownlar) -->
    <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-end mb-12 px-4 sm:px-0">
        <div class="text-center">
            <label class="block text-xs font-medium text-slate-500 dark:text-neutral-400 mb-2 uppercase tracking-wider transition-colors">1. Özgeçmiş</label>
            <div class="relative">
                <select id="selectResume1" onchange="updateCompare()" class="w-full bg-white dark:bg-[#121212] border border-slate-200 dark:border-neutral-800 rounded-2xl pl-4 pr-10 py-3 text-sm font-medium text-slate-700 dark:text-neutral-200 shadow-sm focus:ring-2 focus:ring-slate-200 dark:focus:ring-neutral-700 focus:outline-none appearance-none text-left cursor-pointer hover:border-slate-300 dark:hover:border-neutral-600 transition-all">
                    <option value="">-- Seçiniz --</option>
                    @foreach (var resume in resumesList)
                    {
                        <!option value="@resume.Id" @(resume1?.Id == resume.Id ? "selected" : "")>
                            @resume.FileName
                        </!option>
                    }
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-neutral-500">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="pb-3 px-4">
            <span class="text-[10px] font-bold text-slate-300 dark:text-neutral-600 uppercase tracking-widest text-center block transition-colors">Vs</span>
        </div>

        <div class="text-center">
            <label class="block text-xs font-medium text-slate-500 dark:text-neutral-400 mb-2 uppercase tracking-wider transition-colors">2. Özgeçmiş</label>
            <div class="relative">
                <select id="selectResume2" onchange="updateCompare()" class="w-full bg-white dark:bg-[#121212] border border-slate-200 dark:border-neutral-800 rounded-2xl pl-4 pr-10 py-3 text-sm font-medium text-slate-700 dark:text-neutral-200 shadow-sm focus:ring-2 focus:ring-slate-200 dark:focus:ring-neutral-700 focus:outline-none appearance-none text-left cursor-pointer hover:border-slate-300 dark:hover:border-neutral-600 transition-all">
                    <option value="">-- Seçiniz --</option>
                    @foreach (var resume in resumesList)
                    {
                        <!option value="@resume.Id" @(resume2?.Id == resume.Id ? "selected" : "")>
                            @resume.FileName
                        </!option>
                    }
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-neutral-500">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </div>
            </div>
        </div>
    </div>

    @if (resume1 == null && resume2 == null)
    {
        <div class="text-center py-20 bg-white dark:bg-[#121212] border border-slate-200/60 dark:border-neutral-800 rounded-3xl p-8 shadow-sm">
            <svg width="40" height="40" class="mx-auto text-slate-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5v6m3-3H9m4.062-10.062L10.5 4.5H4.5A2.25 2.25 0 0 0 2.25 6.75v10.5A2.25 2.25 0 0 0 4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V9.75A2.25 2.25 0 0 0 19.5 7.5h-5.379a1.5 1.5 0 0 1-1.06-.44z" />
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">Özgeçmiş Seçin</h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">Karşılaştırmaya başlamak için yukarıdan iki farklı özgeçmiş seçin.</p>
        </div>
    }
    else
    {
        <!-- Karşılaştırma Tablosu (Grid Satırları) -->
        <div class="space-y-4 px-4 sm:px-0">

            <!-- Satır 1: Skor -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-center bg-white dark:bg-[#121212] p-6 sm:p-8 rounded-[2rem] border border-slate-100 dark:border-neutral-800 shadow-[0_4px_20px_rgb(0,0,0,0.02)] dark:shadow-black/20 transition-colors">
                <div class="text-center">
                    @if (resume1?.Analysis != null)
                    {
                        <span class="text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors">@resume1.Analysis.Score</span>
                    }
                    else
                    {
                        <span class="text-5xl font-extrabold text-slate-300 dark:text-neutral-700 tracking-tight transition-colors">-</span>
                    }
                </div>
                <div class="w-28 text-center"><span class="text-[11px] font-bold text-slate-400 dark:text-neutral-500 uppercase tracking-widest transition-colors">ATS Skoru</span></div>
                <div class="text-center">
                    @if (resume2?.Analysis != null)
                    {
                        <span class="text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors">@resume2.Analysis.Score</span>
                    }
                    else
                    {
                        <span class="text-5xl font-extrabold text-slate-300 dark:text-neutral-700 tracking-tight transition-colors">-</span>
                    }
                </div>
            </div>

            <!-- Satır 2: Güçlü Yönler -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white dark:bg-[#121212] p-6 sm:p-8 rounded-[2rem] border border-slate-100 dark:border-neutral-800 shadow-[0_4px_20px_rgb(0,0,0,0.02)] dark:shadow-black/20 transition-colors">
                <div>
                    <ul class="text-sm text-slate-600 dark:text-neutral-400 space-y-3 px-2 sm:px-6 transition-colors">
                        @if (resume1?.Analysis?.Strengths != null && resume1.Analysis.Strengths.Any())
                        {
                            @foreach (var strength in resume1.Analysis.Strengths)
                            {
                                <li class="flex items-start">
                                    <svg width="16" height="16" class="text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    <span>@strength</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-slate-400 italic">Bilgi yok</li>
                        }
                    </ul>
                </div>
                <div class="w-28 text-center pt-1"><span class="text-[11px] font-bold text-slate-400 dark:text-neutral-500 uppercase tracking-widest transition-colors">Güçlü Yönler</span></div>
                <div>
                    <ul class="text-sm text-slate-600 dark:text-neutral-400 space-y-3 px-2 sm:px-6 transition-colors">
                        @if (resume2?.Analysis?.Strengths != null && resume2.Analysis.Strengths.Any())
                        {
                            @foreach (var strength in resume2.Analysis.Strengths)
                            {
                                <li class="flex items-start">
                                    <svg width="16" height="16" class="text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    <span>@strength</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-slate-400 italic">Bilgi yok</li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Satır 3: Eksikler -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white dark:bg-[#121212] p-6 sm:p-8 rounded-[2rem] border border-slate-100 dark:border-neutral-800 shadow-[0_4px_20px_rgb(0,0,0,0.02)] dark:shadow-black/20 transition-colors">
                <div>
                    <ul class="text-sm text-slate-600 dark:text-neutral-400 space-y-3 px-2 sm:px-6 transition-colors">
                        @if (resume1?.Analysis?.Weaknesses != null && resume1.Analysis.Weaknesses.Any())
                        {
                            @foreach (var weakness in resume1.Analysis.Weaknesses)
                            {
                                <li class="flex items-start">
                                    <svg width="16" height="16" class="text-red-400 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                                    </svg>
                                    <span>@weakness</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-slate-400 italic">Bilgi yok</li>
                        }
                    </ul>
                </div>
                <div class="w-28 text-center pt-1"><span class="text-[11px] font-bold text-slate-400 dark:text-neutral-500 uppercase tracking-widest transition-colors">Eksikler</span></div>
                <div>
                    <ul class="text-sm text-slate-600 dark:text-neutral-400 space-y-3 px-2 sm:px-6 transition-colors">
                        @if (resume2?.Analysis?.Weaknesses != null && resume2.Analysis.Weaknesses.Any())
                        {
                            @foreach (var weakness in resume2.Analysis.Weaknesses)
                            {
                                <li class="flex items-start">
                                    <svg width="16" height="16" class="text-red-400 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                                    </svg>
                                    <span>@weakness</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-slate-400 italic">Bilgi yok</li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Satır 4: Öneriler -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white dark:bg-[#121212] p-6 sm:p-8 rounded-[2rem] border border-slate-100 dark:border-neutral-800 shadow-[0_4px_20px_rgb(0,0,0,0.02)] dark:shadow-black/20 transition-colors">
                <div>
                    <ul class="text-sm text-slate-600 dark:text-neutral-400 space-y-3 px-2 sm:px-6 transition-colors">
                        @if (resume1?.Analysis?.Suggestions != null && resume1.Analysis.Suggestions.Any())
                        {
                            @foreach (var suggestion in resume1.Analysis.Suggestions)
                            {
                                <li class="flex items-start">
                                    <svg width="8" height="8" class="text-slate-400 mr-2 flex-shrink-0 mt-1.5" fill="currentColor" viewBox="0 0 8 8">
                                        <circle cx="4" cy="4" r="3" />
                                    </svg>
                                    <span>@suggestion</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-slate-400 italic">Bilgi yok</li>
                        }
                    </ul>
                </div>
                <div class="w-28 text-center pt-1"><span class="text-[11px] font-bold text-slate-400 dark:text-neutral-500 uppercase tracking-widest transition-colors">Öneriler</span></div>
                <div>
                    <ul class="text-sm text-slate-600 dark:text-neutral-400 space-y-3 px-2 sm:px-6 transition-colors">
                        @if (resume2?.Analysis?.Suggestions != null && resume2.Analysis.Suggestions.Any())
                        {
                            @foreach (var suggestion in resume2.Analysis.Suggestions)
                            {
                                <li class="flex items-start">
                                    <svg width="8" height="8" class="text-slate-400 mr-2 flex-shrink-0 mt-1.5" fill="currentColor" viewBox="0 0 8 8">
                                        <circle cx="4" cy="4" r="3" />
                                    </svg>
                                    <span>@suggestion</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-slate-400 italic">Bilgi yok</li>
                        }
                    </ul>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    <script>
        function updateCompare() {
            var id1 = document.getElementById("selectResume1").value;
            var id2 = document.getElementById("selectResume2").value;
            var url = "@Url.Action("Compare", "Resumes")";
            window.location.href = url + "?id1=" + id1 + "&id2=" + id2;
        }
    </script>
}
