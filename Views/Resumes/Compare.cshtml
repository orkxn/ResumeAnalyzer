@model ResumeAnalyzer.ViewModels.CompareViewModel
@{
    ViewData["Title"] = "Karşılaştırma";
}

<div class="max-w-5xl mx-auto pb-12">

    <!-- Header -->
    <div class="text-center mb-10">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Özgeçmiş Karşılaştırma</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">İki farklı özgeçmişi özellik bazında yan yana inceleyin.</p>
    </div>

    <!-- Selection Row -->
    <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-end mb-10">
        <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wider">1. Özgeçmiş</label>
            <select id="selectResume1" onchange="updateCompare()"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-500 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">
                <option value="">-- Seçiniz --</option>
                @foreach (var resume in Model.AvailableResumes)
                {
                    if (Model.SelectedId1 == resume.Id)
                    {
                        <option value="@resume.Id" selected>@resume.FileName</option>
                    }
                    else
                    {
                        <option value="@resume.Id">@resume.FileName</option>
                    }
                }
            </select>
        </div>

        <div class="pb-3 flex items-end justify-center">
            <div class="w-9 h-9 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl flex items-center justify-center">
                <i data-lucide="git-compare" class="w-4 h-4 text-gray-400 dark:text-gray-500"></i>
            </div>
        </div>

        <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wider">2. Özgeçmiş</label>
            <select id="selectResume2" onchange="updateCompare()"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-500 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">
                <option value="">-- Seçiniz --</option>
                @foreach (var resume in Model.AvailableResumes)
                {
                    if (Model.SelectedId2 == resume.Id)
                    {
                        <option value="@resume.Id" selected>@resume.FileName</option>
                    }
                    else
                    {
                        <option value="@resume.Id">@resume.FileName</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (Model.Resume1 == null && Model.Resume2 == null)
    {
        <!-- Empty State -->
        <div class="text-center py-20 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm">
            <div class="w-14 h-14 bg-gray-100 dark:bg-gray-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="git-compare" class="w-7 h-7 text-gray-400 dark:text-gray-500"></i>
            </div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1">Özgeçmiş Seçin</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Karşılaştırmaya başlamak için yukarıdan iki farklı özgeçmiş seçin.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">

            <!-- Row: Score -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-center bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm">
                <div class="text-center">
                    @if (Model.Resume1?.Analysis != null)
                    {
                        <span class="text-5xl font-extrabold text-gray-900 dark:text-white">@Model.Resume1.Analysis.Score</span>
                    }
                    else { <span class="text-5xl font-extrabold text-gray-300 dark:text-gray-700">—</span> }
                </div>
                <div class="w-24 text-center">
                    <span class="text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest block">ATS Skoru</span>
                </div>
                <div class="text-center">
                    @if (Model.Resume2?.Analysis != null)
                    {
                        <span class="text-5xl font-extrabold text-gray-900 dark:text-white">@Model.Resume2.Analysis.Score</span>
                    }
                    else { <span class="text-5xl font-extrabold text-gray-300 dark:text-gray-700">—</span> }
                </div>
            </div>

            <!-- Row: Strengths -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm">
                <ul class="space-y-2.5">
                    @if (Model.Resume1?.Analysis?.Strengths != null && Model.Resume1.Analysis.Strengths.Any())
                    {
                        @foreach (var s in Model.Resume1.Analysis.Strengths)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="check" class="w-4 h-4 text-green-500 shrink-0 mt-0.5"></i><span>@s</span>
                            </li>
                        }
                    }
                    else { <li class="text-sm text-gray-400 italic">Bilgi yok</li> }
                </ul>
                <div class="w-24 text-center pt-1">
                    <span class="text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest block">Güçlü Yönler</span>
                </div>
                <ul class="space-y-2.5">
                    @if (Model.Resume2?.Analysis?.Strengths != null && Model.Resume2.Analysis.Strengths.Any())
                    {
                        @foreach (var s in Model.Resume2.Analysis.Strengths)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="check" class="w-4 h-4 text-green-500 shrink-0 mt-0.5"></i><span>@s</span>
                            </li>
                        }
                    }
                    else { <li class="text-sm text-gray-400 italic">Bilgi yok</li> }
                </ul>
            </div>

            <!-- Row: Weaknesses -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm">
                <ul class="space-y-2.5">
                    @if (Model.Resume1?.Analysis?.Weaknesses != null && Model.Resume1.Analysis.Weaknesses.Any())
                    {
                        @foreach (var w in Model.Resume1.Analysis.Weaknesses)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="minus" class="w-4 h-4 text-red-400 shrink-0 mt-0.5"></i><span>@w</span>
                        </li>
                        }
                    }
                    else { <li class="text-sm text-gray-400 italic">Bilgi yok</li> }
                </ul>
                <div class="w-24 text-center pt-1">
                    <span class="text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest block">Eksikler</span>
                </div>
                <ul class="space-y-2.5">
                    @if (Model.Resume2?.Analysis?.Weaknesses != null && Model.Resume2.Analysis.Weaknesses.Any())
                    {
                        @foreach (var w in Model.Resume2.Analysis.Weaknesses)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="minus" class="w-4 h-4 text-red-400 shrink-0 mt-0.5"></i><span>@w</span>
                            </li>
                        }
                    }
                    else { <li class="text-sm text-gray-400 italic">Bilgi yok</li> }
                </ul>
            </div>

            <!-- Row: Suggestions -->
            <div class="grid grid-cols-[1fr_auto_1fr] gap-6 items-start bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm">
                <ul class="space-y-2.5">
                    @if (Model.Resume1?.Analysis?.Suggestions != null && Model.Resume1.Analysis.Suggestions.Any())
                    {
                        @foreach (var s in Model.Resume1.Analysis.Suggestions)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="chevron-right" class="w-4 h-4 text-blue-400 shrink-0 mt-0.5"></i><span>@s</span>
                            </li>
                        }
                    }
                    else { <li class="text-sm text-gray-400 italic">Bilgi yok</li> }
                </ul>
                <div class="w-24 text-center pt-1">
                    <span class="text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest block">Öneriler</span>
                </div>
                <ul class="space-y-2.5">
                    @if (Model.Resume2?.Analysis?.Suggestions != null && Model.Resume2.Analysis.Suggestions.Any())
                    {
                        @foreach (var s in Model.Resume2.Analysis.Suggestions)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                                <i data-lucide="chevron-right" class="w-4 h-4 text-blue-400 shrink-0 mt-0.5"></i><span>@s</span>
                            </li>
                        }
                    }
                    else { <li class="text-sm text-gray-400 italic">Bilgi yok</li> }
                </ul>
            </div>

        </div>
    }
</div>

@section Scripts {
    <script>
        function updateCompare() {
            var id1 = document.getElementById("selectResume1").value;
            var id2 = document.getElementById("selectResume2").value;
            window.location.href = "@Url.Action("Compare", "Resumes")?id1=" + id1 + "&id2=" + id2;
        }
    </script>
}