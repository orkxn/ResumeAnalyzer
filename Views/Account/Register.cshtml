@model ResumeAnalyzer.DTOs.RegisterRequestDto
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="max-w-md mx-auto mt-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm p-8">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="user-plus" class="w-6 h-6 text-purple-600 dark:text-purple-400"></i>
            </div>
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Hesap Oluştur</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">CV Analiz platformuna katılın</p>
        </div>

        <form asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-5">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
            {
                <div class="flex items-center gap-3 p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 rounded-xl text-sm">
                    <i data-lucide="circle-x" class="w-4 h-4 shrink-0"></i>
                    <div asp-validation-summary="ModelOnly" class="list-none"></div>
                </div>
            }

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">E-posta</label>
                <input asp-for="Email" type="email"
                       class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-500 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                       autocomplete="username" placeholder="ornek@mail.com" />
                <span asp-validation-for="Email" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Şifre</label>
                <input asp-for="Password" type="password"
                       class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-500 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                       autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Şifre Tekrarı</label>
                <input asp-for="ConfirmPassword" type="password"
                       class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-500 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                       autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full flex items-center justify-center gap-2 text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 font-medium rounded-xl text-sm px-5 py-3 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800 transition-colors shadow-sm mt-2">
                <i data-lucide="user-plus" class="w-4 h-4"></i>
                Kayıt Ol
            </button>
        </form>

        <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-6">
            Zaten bir hesabınız var mı?
            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]"
               class="text-blue-600 dark:text-blue-400 hover:underline font-medium ml-1">Giriş yapın</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
