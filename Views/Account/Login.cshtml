@model ResumeAnalyzer.DTOs.LoginRequestDto
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="max-w-sm mx-auto mt-12 bg-white dark:bg-[#121212] p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-black/30 border border-gray-100 dark:border-neutral-800 transition-colors">
    <div class="text-center mb-8">
        <h1 class="text-2xl font-semibold text-slate-900 dark:text-white tracking-tight transition-colors">Hoş Geldiniz</h1>
        <p class="text-sm text-slate-500 dark:text-neutral-400 mt-2 transition-colors">Devam etmek için hesabınıza giriş yapın</p>
    </div>

    <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-5">
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="p-3.5 bg-white dark:bg-neutral-800 border border-gray-200 dark:border-neutral-700 text-slate-900 dark:text-neutral-200 rounded-2xl text-xs text-center font-medium shadow-sm">
                <div asp-validation-summary="ModelOnly" class="list-none"></div>
            </div>
        }

        @if (TempData["RegistrationSuccess"] != null)
        {
            <div class="p-3 bg-green-50 dark:bg-green-950/30 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 rounded-2xl text-xs text-center font-medium">
                @TempData["RegistrationSuccess"]
            </div>
        }

        <div>
            <label asp-for="Email" class="block text-sm font-medium text-slate-700 dark:text-neutral-300 mb-1.5 ml-1 transition-colors">E-posta</label>
            <input asp-for="Email" type="email" class="w-full px-4 py-2.5 bg-[#fbfbfd] dark:bg-[#0a0a0a] border border-gray-200 dark:border-neutral-700 rounded-2xl focus:outline-none focus:ring-2 focus:ring-slate-500/20 dark:focus:ring-neutral-400/20 focus:border-slate-500 dark:focus:border-neutral-400 transition-all text-sm text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-neutral-500" autocomplete="username" aria-required="true" placeholder="ornek@mail.com" />
            <span asp-validation-for="Email" class="text-red-500 dark:text-red-400 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div>
            <label asp-for="Password" class="block text-sm font-medium text-slate-700 dark:text-neutral-300 mb-1.5 ml-1 transition-colors">Şifre</label>
            <input asp-for="Password" type="password" class="w-full px-4 py-2.5 bg-[#fbfbfd] dark:bg-[#0a0a0a] border border-gray-200 dark:border-neutral-700 rounded-2xl focus:outline-none focus:ring-2 focus:ring-slate-500/20 dark:focus:ring-neutral-400/20 focus:border-slate-500 dark:focus:border-neutral-400 transition-all text-sm text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-neutral-500" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
            <span asp-validation-for="Password" class="text-red-500 dark:text-red-400 text-xs mt-1.5 ml-1 block"></span>
        </div>

        <div class="flex items-center justify-between pl-1">
            <div class="flex items-center space-x-2">
                <input asp-for="RememberMe" type="checkbox" id="RememberMeCheck" class="w-4 h-4 text-slate-900 bg-gray-100 dark:bg-neutral-800 border-gray-300 dark:border-neutral-600 rounded focus:ring-slate-900 dark:focus:ring-neutral-400 cursor-pointer" />
                <label for="RememberMeCheck" class="text-sm text-slate-600 dark:text-neutral-400 cursor-pointer mb-0 transition-colors">Beni Hatırla</label>
            </div>
            <a asp-controller="Account" asp-action="ForgotPassword" class="text-sm text-slate-600 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white font-medium transition-colors">Şifremi unuttum</a>
        </div>

        <button type="submit" class="w-full bg-slate-900 dark:bg-neutral-200 hover:bg-black dark:hover:bg-neutral-300 text-white dark:text-neutral-900 font-medium py-3 rounded-2xl transition-all shadow-md hover:shadow-lg mt-2">
            Giriş Yap
        </button>
    </form>

    <div class="mt-8 text-center">
        <p class="text-sm text-slate-500 dark:text-neutral-400 transition-colors">
            Hesabınız yok mu?
            <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="text-slate-900 dark:text-white hover:text-black dark:hover:text-neutral-200 font-medium transition-colors underline decoration-slate-300 dark:decoration-neutral-600 underline-offset-4">Hemen kayıt olun</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
