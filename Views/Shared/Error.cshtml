@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="max-w-2xl mx-auto mt-12 text-center">
    <div class="bg-white dark:bg-[#121212] border border-red-100/50 dark:border-red-900/30 rounded-3xl p-10 shadow-sm transition-colors">
        <div class="mx-auto w-14 h-14 mb-6 p-3 bg-red-50 dark:bg-red-900/30 rounded-2xl text-red-500 dark:text-red-400 transition-colors">
            @if (Model.IconType == "404")
            {
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h1.5m-1.5-3h2.25m-2.25-3h3m2.25 9H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.03 0 1.9.7 2.122 1.636m-9.495 0A2.25 2.25 0 0 0 6 6.108V18a2.25 2.25 0 0 0 2.25 2.25h1.5" />
                </svg>
            }
            else if (Model.IconType == "403")
            {
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
            }
            else
            {
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                </svg>
            }
        </div>

        <h1 class="text-2xl font-semibold text-slate-900 dark:text-white tracking-tight mb-2 transition-colors">@(Model.Title ?? "Bir hata oluştu")</h1>
        <p class="text-sm text-slate-500 dark:text-neutral-400 mb-8 transition-colors">@(Model.ErrorMessage ?? "İsteğiniz işlenirken beklenmeyen bir sorun yaşandı. Lütfen daha sonra tekrar deneyin.")</p>

        @if (Model.ShowRequestId)
        {
            <p class="text-xs text-slate-400 dark:text-neutral-500 mb-8 transition-colors">
                İstek Kimliği: <code class="px-2 py-1 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-lg text-slate-600 dark:text-neutral-300">@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white dark:text-neutral-900 bg-slate-900 dark:bg-neutral-200 rounded-full hover:bg-black dark:hover:bg-neutral-300 transition-all shadow-sm">
            Ana Sayfaya Dön
        </a>
    </div>
</div>
