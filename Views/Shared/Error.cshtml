@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="max-w-2xl mx-auto mt-12 text-center">
    <div class="bg-white dark:bg-[#121212] border border-red-100/50 dark:border-red-900/30 rounded-3xl p-10 shadow-sm transition-colors">
        <div class="mx-auto w-14 h-14 mb-6 p-3 bg-red-50 dark:bg-red-900/30 rounded-2xl text-red-500 dark:text-red-400 transition-colors">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
        </div>

        <h1 class="text-2xl font-semibold text-slate-900 dark:text-white tracking-tight mb-2 transition-colors">Bir hata oluştu</h1>
        <p class="text-sm text-slate-500 dark:text-neutral-400 mb-8 transition-colors">İsteğiniz işlenirken beklenmeyen bir sorun yaşandı. Lütfen daha sonra tekrar deneyin.</p>

        @if (Model.ShowRequestId)
        {
            <p class="text-xs text-slate-400 dark:text-neutral-500 mb-8 transition-colors">
                İstek Kimliği: <code class="px-2 py-1 bg-slate-50 dark:bg-neutral-800 border border-slate-200 dark:border-neutral-700 rounded-lg text-slate-600 dark:text-neutral-300">@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white dark:text-neutral-900 bg-slate-900 dark:bg-neutral-200 rounded-full hover:bg-black dark:hover:bg-neutral-300 transition-all shadow-sm">
            Ana Sayfaya Dön
        </a>
    </div>
</div>
