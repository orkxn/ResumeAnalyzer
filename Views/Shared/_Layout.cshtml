<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CV Analiz</title>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script>
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased flex flex-col min-h-screen">

    <nav class="bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800 sticky top-0 z-50">
        <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">

                <!-- Logo -->
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 text-lg font-semibold text-gray-900 dark:text-white">
                    <i data-lucide="file-scan" class="w-5 h-5 text-blue-600 dark:text-blue-400"></i>
                    CV<span class="text-gray-400 dark:text-gray-500 font-normal">Analiz</span>
                </a>

                <!-- Desktop Nav Links -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="hidden md:flex items-center gap-6">
                        <a asp-controller="Resumes" asp-action="Index" class="flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                            <i data-lucide="layout-grid" class="w-4 h-4"></i>
                            Özgeçmişler
                        </a>
                        <a asp-controller="Resumes" asp-action="Upload" class="flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                            <i data-lucide="upload" class="w-4 h-4"></i>
                            Yeni Yükle
                        </a>
                        <a asp-controller="Resumes" asp-action="Compare" class="flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                            <i data-lucide="git-compare" class="w-4 h-4"></i>
                            Karşılaştır
                        </a>
                    </div>
                }

                <!-- Right Actions -->
                <div class="flex items-center gap-3">
                    <!-- Theme toggle -->
                    <button id="theme-toggle" type="button" class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" title="Temayı Değiştir">
                        <i data-lucide="sun" id="theme-toggle-light-icon" class="w-4 h-4 hidden"></i>
                        <i data-lucide="moon" id="theme-toggle-dark-icon" class="w-4 h-4 hidden"></i>
                    </button>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="hidden sm:block text-sm text-gray-600 dark:text-gray-400">@User.Identity.Name</span>
                        <a asp-controller="Account" asp-action="Logout" class="text-sm font-medium text-red-500 hover:text-red-600 dark:text-red-400 dark:hover:text-red-300 transition-colors">
                            Çıkış
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register" class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                            Kayıt Ol
                        </a>
                        <a asp-controller="Account" asp-action="Login" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-700 rounded-lg transition-colors shadow-sm">
                            Giriş Yap
                        </a>
                    }

                    <!-- Mobile hamburger -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button data-collapse-toggle="mobile-menu" type="button" class="md:hidden p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                            <i data-lucide="menu" class="w-5 h-5"></i>
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Mobile Menu -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 dark:border-gray-800">
                <div class="px-4 py-3 space-y-1">
                    <a asp-controller="Resumes" asp-action="Index" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                        <i data-lucide="layout-grid" class="w-4 h-4"></i> Özgeçmişler
                    </a>
                    <a asp-controller="Resumes" asp-action="Upload" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                        <i data-lucide="upload" class="w-4 h-4"></i> Yeni Yükle
                    </a>
                    <a asp-controller="Resumes" asp-action="Compare" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                        <i data-lucide="git-compare" class="w-4 h-4"></i> Karşılaştır
                    </a>
                </div>
            </div>
        }
    </nav>

    <main class="flex-grow max-w-screen-xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-10">
        @RenderBody()
    </main>

    <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-auto">
        <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-xs text-gray-400 dark:text-gray-500">
                &copy; @DateTime.Now.Year CV Analiz. Tüm hakları saklıdır.
            </p>
            <div class="flex gap-4 text-xs text-gray-400 dark:text-gray-500">
                <a asp-controller="Home" asp-action="Privacy" class="hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Gizlilik Politikası</a>
                <a asp-controller="Home" asp-action="Terms" class="hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Kullanım Şartları</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Flowbite JS -->
    <script src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Render Lucide icons
        lucide.createIcons();

        // Theme toggle
        (function () {
            var darkIcon = document.getElementById('theme-toggle-dark-icon');
            var lightIcon = document.getElementById('theme-toggle-light-icon');
            var toggleBtn = document.getElementById('theme-toggle');

            function syncIcons() {
                var isDark = document.documentElement.classList.contains('dark');
                lightIcon.classList.toggle('hidden', !isDark);
                darkIcon.classList.toggle('hidden', isDark);
            }

            syncIcons();

            toggleBtn.addEventListener('click', function () {
                var isDark = document.documentElement.classList.toggle('dark');
                localStorage.setItem('color-theme', isDark ? 'dark' : 'light');
                syncIcons();
                lucide.createIcons();
            });

            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
                if (!localStorage.getItem('color-theme')) {
                    document.documentElement.classList.toggle('dark', e.matches);
                    syncIcons();
                    lucide.createIcons();
                }
            });
        })();
    </script>
</body>
</html>